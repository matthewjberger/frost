// Mini-Frost: a compiler written in Frost, in the data-oriented style.
//
// It reads a program written in a subset of Frost's own syntax (definitions of
// the form `name :: fn(p: i64) -> i64 { ... }`, `x := e` and `mut x : i64 = e`
// locals, assignment, `print`, `if`/`else`, `while`, arithmetic, comparisons,
// and boolean operators, with calls and recursion), lexes it into a token
// stream, parses that into an abstract syntax tree in an arena, and walks the
// tree to emit a C translation unit. Compiling and running that C produces the
// program's output, so this is a real code generator written in Frost that emits
// native code, the same way Frost's own primary backend emits C and links it.
//
// The whole thing is written against the native data-oriented surface: no
// closures, no dynamic collections, references are second-class, and every
// mutable working set is an arena (the token stream, the AST, and the function
// table). The arenas are the language's own allocator (docs/allocators.md), a
// generic bump allocator over one `malloc` per arena, not a runtime pool.
//
// The AST is stored in an arena of Node records. A node names its children by
// their arena index (a plain integer), which is the data-oriented replacement
// for pointers between heap nodes. Sibling statements, parameters, and call
// arguments are each threaded through a `next` field into a singly linked list.
//
// Identifiers are byte ranges into the source (offset + length). A local is
// emitted as its own name in the generated C, so no local symbol table is
// needed. Function names are interned to small integer indices through one
// global table, and a name becomes the `mf_<index>` of its emitted C function,
// which also keeps user names from colliding with the C runtime.

malloc          :: extern fn(size: i64) -> ^u8
frost_byte_at   :: extern fn(s: ^i8, i: i64) -> i64
frost_str_len   :: extern fn(s: ^i8) -> i64
frost_emit_str  :: extern fn(s: ^i8)
frost_emit_int  :: extern fn(value: i64)
frost_emit_char :: extern fn(byte: i64)
frost_read_file :: extern fn(path: ^i8) -> ^i8
frost_byte_set  :: extern fn(buffer: ^i8, index: i64, value: i64)

// Diagnostics. The emitted C goes to stdout, so an error is composed on stderr
// piece by piece and frost_die ends the process.
frost_error     :: extern fn(text: ^i8)
frost_error_src :: extern fn(text: ^i8, offset: i64, length: i64)
frost_error_int :: extern fn(value: i64)
frost_die       :: extern fn()
frost_is_windows :: extern fn() -> i64
frost_getenv    :: extern fn(name: ^i8) -> ^i8

// Node kinds.
NODE_NUM        :: 0
NODE_VAR        :: 1
NODE_BIN        :: 2
NODE_LET        :: 3
NODE_ASSIGN     :: 4
NODE_PRINT      :: 5
NODE_IF         :: 6
NODE_WHILE      :: 7
NODE_RETURN     :: 8
NODE_CALL       :: 9
NODE_FUNC       :: 10
NODE_PARAM      :: 11
NODE_ARG        :: 12
NODE_STRUCT_LIT :: 13
NODE_FIELD      :: 14
NODE_FIELD_INIT :: 15
NODE_DEREF      :: 16
NODE_INDEX      :: 17
NODE_ADDROF     :: 18
NODE_PTR_CAST   :: 19
NODE_SIZEOF     :: 20
NODE_EXPRSTMT   :: 21
NODE_MATCH      :: 22
NODE_CASE       :: 23
NODE_EXTERN     :: 24
NODE_STRLIT     :: 25
NODE_TYPEVAL    :: 26
NODE_WITH       :: 27

// Type codes. A type is one i64. The primitives are small constants; a struct is
// STRUCT_BASE plus its table index; a pointer to a type T (also how a borrow
// parameter is modelled, since a borrow is a C pointer) is POINTER_BASE plus T, so
// pointer nesting composes by repeated addition.
TY_I64   :: 0
TY_I8    :: 1
TY_BOOL  :: 2
TY_U8    :: 3
TY_VOID  :: 4
TY_PARAM :: 5
STRUCT_BASE  :: 16
POINTER_BASE :: 1000000

// Binary operator codes.
OP_ADD :: 0
OP_SUB :: 1
OP_MUL :: 2
OP_DIV :: 3
OP_MOD :: 4
OP_LT  :: 5
OP_GT  :: 6
OP_LE  :: 7
OP_GE  :: 8
OP_EQ  :: 9
OP_NE  :: 10
OP_AND :: 11
OP_OR  :: 12

// Token kinds. The lexer turns the source into a flat arena of these before the
// parser runs, so the parser peeks token kinds rather than raw bytes. Identifier
// runs that spell a keyword are classified to their keyword kind while lexing.
TOK_EOF       :: 0
TOK_INT       :: 1
TOK_IDENT     :: 2
TOK_STR       :: 3
TOK_KW_FN     :: 10
TOK_KW_LET    :: 11
TOK_KW_IF     :: 12
TOK_KW_ELSE   :: 13
TOK_KW_WHILE  :: 14
TOK_KW_RETURN :: 15
TOK_KW_PRINT  :: 16
TOK_KW_STRUCT :: 17
TOK_KW_MATCH  :: 18
TOK_KW_CASE   :: 19
TOK_KW_EXTERN :: 20
TOK_KW_TRUE   :: 21
TOK_KW_FALSE  :: 22
TOK_KW_MUT    :: 23
TOK_KW_MOVE   :: 24
TOK_KW_LINEAR :: 25
TOK_KW_USES   :: 26
TOK_KW_WITH   :: 27
TOK_KW_IMPORT :: 28
TOK_KW_EXPORT :: 29
TOK_KW_ENUM   :: 30
TOK_LPAREN    :: 40
TOK_RPAREN    :: 41
TOK_LBRACE    :: 42
TOK_RBRACE    :: 43
TOK_LBRACKET  :: 44
TOK_RBRACKET  :: 45
TOK_COMMA     :: 46
TOK_DOT       :: 47
TOK_COLON     :: 48
TOK_COLONCOLON :: 49
TOK_COLONEQ   :: 50
TOK_ARROW     :: 51
TOK_CARET     :: 52
TOK_AMP       :: 53
TOK_ASSIGN    :: 54
TOK_PLUS      :: 55
TOK_MINUS     :: 56
TOK_STAR      :: 57
TOK_SLASH     :: 58
TOK_PERCENT   :: 59
TOK_LT        :: 60
TOK_LE        :: 61
TOK_GT        :: 62
TOK_GE        :: 63
TOK_EQEQ      :: 64
TOK_NE        :: 65
TOK_ANDAND    :: 66
TOK_OROR      :: 67
TOK_DOLLAR    :: 68
TOK_BANG      :: 69
TOK_QUESTION  :: 70

// Character codes (the language has no character literals).
CH_TAB     :: 9
CH_LF      :: 10
CH_CR      :: 13
CH_SPACE   :: 32
CH_BANG    :: 33
CH_QUESTION :: 63
CH_PERCENT :: 37
CH_AMP     :: 38
CH_LPAREN  :: 40
CH_RPAREN  :: 41
CH_STAR    :: 42
CH_PLUS    :: 43
CH_COMMA   :: 44
CH_MINUS   :: 45
CH_SLASH   :: 47
CH_0       :: 48
CH_9       :: 57
CH_SEMI    :: 59
CH_LT      :: 60
CH_EQ      :: 61
CH_GT      :: 62
CH_LBRACE  :: 123
CH_PIPE    :: 124
CH_RBRACE  :: 125
CH_LOWER_A :: 97
CH_LOWER_Z :: 122
CH_DQUOTE     :: 34
CH_DOLLAR     :: 36
CH_DOT        :: 46
CH_COLON      :: 58
CH_UPPER_A    :: 65
CH_UPPER_Z    :: 90
CH_LBRACKET   :: 91
CH_RBRACKET   :: 93
CH_CARET      :: 94
CH_UNDERSCORE :: 95
CH_BACKSLASH  :: 92
CH_LOWER_N    :: 110
CH_LOWER_T    :: 116

Node :: struct {
    kind: i64,
    a: i64,
    b: i64,
    c: i64,
    val: i64,
    next: i64,
}

// An interned function name: a byte range into the source, a flag marking it as
// an `extern` (so calls emit its real name rather than mf_<index>), and its
// return type so a call expression can be typed.
// `cap_off`/`cap_len` name the allocation capability a `uses` function draws:
// the synthesized binding its body sees and its callers must supply. `uses_ty`
// is the capability's type, or -1 for a function that allocates from nothing.
Sym :: struct {
    off: i64,
    len: i64,
    is_extern: i64,
    ret_type: i64,
    params: i64,
    defined: i64,
    uses_ty: i64,
    cap_off: i64,
    cap_len: i64,
}

// A compile-time integer constant `name :: value`, inlined at each use.
ConstDef :: struct {
    name_off: i64,
    name_len: i64,
    value: i64,
}

// A lexed token. `off`/`len` are the byte range in the source (used to intern
// identifiers and to re-emit string literals); `value` holds the parsed integer
// for a TOK_INT. `kind` is one of the TOK_ constants.
Token :: struct {
    kind: i64,
    off: i64,
    len: i64,
    value: i64,
}

// A struct declaration. `field_head` is the first field's index in the field
// arena (or -1). A generic template (is_generic = 1) leaves fields unparsed and
// records its type parameter name and the token index of its `{` so each
// instantiation can re-parse the fields with the parameter bound. A monomorphized
// instance (instance_id >= 0) is emitted as `<name>_<instance_id>` rather than by
// its source name.
StructDef :: struct {
    name_off: i64,
    name_len: i64,
    field_head: i64,
    is_generic: i64,
    tparam_off: i64,
    tparam_len: i64,
    field_token: i64,
    instance_id: i64,
    is_linear: i64,
}

// A monomorphized instance of a generic struct: which template, the concrete
// type argument, and the concrete struct's index in the struct table.
MonoRet :: struct {
    fn_index: i64,
    arg: i64,
    ret: i64,
}

Instance :: struct {
    generic_index: i64,
    arg: i64,
    struct_index: i64,
}

// A generic function template: its interned name index, its type parameter name,
// and the token index of its name, so it can be re-parsed and emitted once per
// concrete type argument with the parameter bound.
GenericFn :: struct {
    fn_index: i64,
    tparam_off: i64,
    tparam_len: i64,
    token_start: i64,
}

// One field of a struct: its name (byte range), its type code, and the next
// field's index in the field arena.
StructField :: struct {
    name_off: i64,
    name_len: i64,
    ty: i64,
    next: i64,
}

// One source file. A name is an offset into the buffer every file's text was
// laid into, and a module's range is what says which file wrote it.
Module :: struct {
    path: ^i8,
    start: i64,
    finish: i64,
}

// A name a module offers to whoever imports it, from an `export a, b` line. A
// top-level name not listed is the module's own: another file naming it is
// naming something else, and two modules may each keep one of the same name.
Export :: struct {
    module: i64,
    off: i64,
    len: i64,
}

// One variant of an enum: which enum it belongs to, its name, and the tag that
// stands for it. An enum is laid out as a struct carrying the tag beside every
// variant's fields, each named for the variant it came from, so a variant is a
// tag value and a set of field names rather than a type of its own.
Variant :: struct {
    enum_ty: i64,
    name_off: i64,
    name_len: i64,
    tag: i64,
}

// A local's type binding during code generation. The table is rebuilt per
// function and maps a local's name (byte range) to its type code, so a field
// access or a `:=` can be typed by walking it.
LocalVar :: struct {
    name_off: i64,
    name_len: i64,
    ty: i64,
}

// A growable, index-addressed arena over a single heap allocation. This is the
// data-oriented allocator from docs/allocators.md, generic over its element:
// arena_push appends and returns the element's index, arena_at turns an index
// back into a pointer. The compiler is asked only for the raw memory (malloc)
// and the pointer reinterpret; the bump logic is here.
Arena :: struct($T: Type) {
    data: ^T,
    cap: i64,
    count: i64,
}

arena_make :: fn($T: Type, cap: i64) -> Arena<T> {
    bytes := malloc(cap * sizeof(T))
    Arena { data = ptr_cast($T, bytes), cap = cap, count = 0 }
}

arena_push :: fn(mut a: Arena<$T>, move value: $T) -> i64 {
    // An arena is a single fixed allocation, so running past it writes over
    // whatever the allocator put next and the damage surfaces somewhere else
    // entirely. Say so here instead.
    if (a.count >= a.cap) {
        frost_error("frost: an arena ran out of room")
        frost_die()
    }
    id := a.count
    a.data[id] = value
    a.count = a.count + 1
    id
}

// An index outside the arena reads whatever happens to sit there, which lands
// inside the heap on one host and outside the mapping on another, so the same
// mistake is silent corruption in one place and a crash with no explanation in
// the other. Answer for it here instead.
arena_at :: fn(a: Arena<$T>, id: i64) -> ^T {
    if (id < 0 || id >= a.count) {
        frost_error("frost: an arena was indexed out of range: ")
        frost_error_int(id)
        frost_die()
    }
    ptr_to(a.data[id])
}

Parser :: struct {
    src: ^i8,
    tokens: Arena<Token>,
    ti: i64,
    arena: Arena<Node>,
    fns: Arena<Sym>,
    structs: Arena<StructDef>,
    fields: Arena<StructField>,
    locals: Arena<LocalVar>,
    consts: Arena<ConstDef>,
    instances: Arena<Instance>,
    generic_fns: Arena<GenericFn>,
    type_param_off: i64,
    type_param_len: i64,
    type_binding: i64,
    binding_active: i64,
    saw_type_param: i64,
    last_return_type: i64,
    no_struct_lit: bool,
    last_type_was_generic: i64,
    moved: Arena<LocalVar>,
    label_id: i64,
    abi_windows: i64,
    asm_temp: i64,
    asm_ret: i64,
    sret_slot: i64,
    mono_rets: Arena<MonoRet>,
    current_ret: i64,
    current_fn_off: i64,
    current_fn_len: i64,
    tainted: Arena<LocalVar>,
    inner: Arena<LocalVar>,
    region_off: i64,
    region_len: i64,
    region_returns: i64,
    modules: Arena<Module>,
    exports: Arena<Export>,
    export_names: ^i8,
    result_ty: i64,
    failure_ty: i64,
    variants: Arena<Variant>,
    match_count: i64,
    pending: Arena<LocalVar>,
    try_count: i64,
    name_tag: i64,
    name_value: i64,
    name_error: i64,
    synth_next: i64,
    prov_kind: i64,
    prov_off: i64,
    prov_len: i64,
}

is_digit :: fn(c: i64) -> bool {
    c >= CH_0 && c <= CH_9
}

is_ident_start :: fn(c: i64) -> bool {
    (c >= CH_LOWER_A && c <= CH_LOWER_Z)
        || (c >= CH_UPPER_A && c <= CH_UPPER_Z)
        || c == CH_UNDERSCORE
}

is_ident_cont :: fn(c: i64) -> bool {
    is_ident_start(c) || (c >= CH_0 && c <= CH_9)
}

// ---------------------------------------------------------------------------
// Lexer. One pass over the source builds a flat arena of tokens: identifiers
// (keywords classified to their own kind), integer and string literals, and
// every operator and punctuation mark. Whitespace and `//` comments are dropped
// here so the parser never sees them.
// ---------------------------------------------------------------------------

byte_of :: fn(src: ^i8, index: i64, len: i64) -> i64 {
    if (index >= len) {
        return 0 - 1
    }
    frost_byte_at(src, index)
}

str_range_eq :: fn(src: ^i8, off: i64, len: i64, word: ^i8) -> bool {
    if (frost_str_len(word) != len) {
        return false
    }
    mut k : i64 = 0
    while (k < len) {
        if (frost_byte_at(src, off + k) != frost_byte_at(word, k)) {
            return false
        }
        k = k + 1
    }
    true
}

classify_ident :: fn(src: ^i8, off: i64, len: i64) -> i64 {
    if (str_range_eq(src, off, len, "fn")) { return TOK_KW_FN }
    if (str_range_eq(src, off, len, "if")) { return TOK_KW_IF }
    if (str_range_eq(src, off, len, "let")) { return TOK_KW_LET }
    if (str_range_eq(src, off, len, "mut")) { return TOK_KW_MUT }
    if (str_range_eq(src, off, len, "linear")) { return TOK_KW_LINEAR }
    if (str_range_eq(src, off, len, "move")) { return TOK_KW_MOVE }
    if (str_range_eq(src, off, len, "else")) { return TOK_KW_ELSE }
    if (str_range_eq(src, off, len, "case")) { return TOK_KW_CASE }
    if (str_range_eq(src, off, len, "true")) { return TOK_KW_TRUE }
    if (str_range_eq(src, off, len, "print")) { return TOK_KW_PRINT }
    if (str_range_eq(src, off, len, "while")) { return TOK_KW_WHILE }
    if (str_range_eq(src, off, len, "match")) { return TOK_KW_MATCH }
    if (str_range_eq(src, off, len, "false")) { return TOK_KW_FALSE }
    if (str_range_eq(src, off, len, "return")) { return TOK_KW_RETURN }
    if (str_range_eq(src, off, len, "struct")) { return TOK_KW_STRUCT }
    if (str_range_eq(src, off, len, "extern")) { return TOK_KW_EXTERN }
    if (str_range_eq(src, off, len, "uses")) { return TOK_KW_USES }
    if (str_range_eq(src, off, len, "with")) { return TOK_KW_WITH }
    if (str_range_eq(src, off, len, "import")) { return TOK_KW_IMPORT }
    if (str_range_eq(src, off, len, "export")) { return TOK_KW_EXPORT }
    if (str_range_eq(src, off, len, "enum")) { return TOK_KW_ENUM }
    TOK_IDENT
}

push_token :: fn(mut tokens: Arena<Token>, kind: i64, off: i64, len: i64,
    value: i64) {
    id := arena_push(tokens, Token { kind = kind, off = off, len = len,
        value = value })
    id
}

lex_operator :: fn(src: ^i8, i: i64, len: i64, mut tokens: Arena<Token>) -> i64 {
    c := byte_of(src, i, len)
    d := byte_of(src, i + 1, len)
    if (c == CH_COLON && d == CH_COLON) {
        push_token(tokens, TOK_COLONCOLON, i, 2, 0)
        return i + 2
    }
    if (c == CH_COLON && d == CH_EQ) {
        push_token(tokens, TOK_COLONEQ, i, 2, 0)
        return i + 2
    }
    if (c == CH_MINUS && d == CH_GT) {
        push_token(tokens, TOK_ARROW, i, 2, 0)
        return i + 2
    }
    if (c == CH_LT && d == CH_EQ) {
        push_token(tokens, TOK_LE, i, 2, 0)
        return i + 2
    }
    if (c == CH_GT && d == CH_EQ) {
        push_token(tokens, TOK_GE, i, 2, 0)
        return i + 2
    }
    if (c == CH_EQ && d == CH_EQ) {
        push_token(tokens, TOK_EQEQ, i, 2, 0)
        return i + 2
    }
    if (c == CH_BANG && d == CH_EQ) {
        push_token(tokens, TOK_NE, i, 2, 0)
        return i + 2
    }
    if (c == CH_AMP && d == CH_AMP) {
        push_token(tokens, TOK_ANDAND, i, 2, 0)
        return i + 2
    }
    if (c == CH_PIPE && d == CH_PIPE) {
        push_token(tokens, TOK_OROR, i, 2, 0)
        return i + 2
    }
    mut kind : i64 = TOK_EOF
    if (c == CH_LPAREN) { kind = TOK_LPAREN }
    if (c == CH_RPAREN) { kind = TOK_RPAREN }
    if (c == CH_LBRACE) { kind = TOK_LBRACE }
    if (c == CH_RBRACE) { kind = TOK_RBRACE }
    if (c == CH_LBRACKET) { kind = TOK_LBRACKET }
    if (c == CH_RBRACKET) { kind = TOK_RBRACKET }
    if (c == CH_COMMA) { kind = TOK_COMMA }
    if (c == CH_DOT) { kind = TOK_DOT }
    if (c == CH_COLON) { kind = TOK_COLON }
    if (c == CH_CARET) { kind = TOK_CARET }
    if (c == CH_AMP) { kind = TOK_AMP }
    if (c == CH_EQ) { kind = TOK_ASSIGN }
    if (c == CH_PLUS) { kind = TOK_PLUS }
    if (c == CH_MINUS) { kind = TOK_MINUS }
    if (c == CH_STAR) { kind = TOK_STAR }
    if (c == CH_BANG) { kind = TOK_BANG }
    if (c == CH_QUESTION) { kind = TOK_QUESTION }
    if (c == CH_SLASH) { kind = TOK_SLASH }
    if (c == CH_PERCENT) { kind = TOK_PERCENT }
    if (c == CH_LT) { kind = TOK_LT }
    if (c == CH_GT) { kind = TOK_GT }
    if (c == CH_DOLLAR) { kind = TOK_DOLLAR }
    push_token(tokens, kind, i, 1, 0)
    i + 1
}

tokenize :: fn(src: ^i8, len: i64, mut tokens: Arena<Token>) {
    mut i : i64 = 0
    while (i < len) {
        c := byte_of(src, i, len)
        if (c == CH_SPACE || c == CH_TAB || c == CH_LF || c == CH_CR
            || c == CH_SEMI) {
            i = i + 1
        } else if (c == CH_SLASH && byte_of(src, i + 1, len) == CH_SLASH) {
            while (i < len && byte_of(src, i, len) != CH_LF) {
                i = i + 1
            }
        } else if (is_digit(c)) {
            start := i
            mut value : i64 = 0
            while (is_digit(byte_of(src, i, len))) {
                value = value * 10 + (byte_of(src, i, len) - CH_0)
                i = i + 1
            }
            push_token(tokens, TOK_INT, start, i - start, value)
        } else if (is_ident_start(c)) {
            start := i
            while (is_ident_cont(byte_of(src, i, len))) {
                i = i + 1
            }
            length := i - start
            push_token(tokens, classify_ident(src, start, length), start,
                length, 0)
        } else if (c == CH_DQUOTE) {
            start := i
            i = i + 1
            while (i < len && byte_of(src, i, len) != CH_DQUOTE) {
                if (byte_of(src, i, len) == CH_BACKSLASH) {
                    i = i + 1
                }
                i = i + 1
            }
            i = i + 1
            push_token(tokens, TOK_STR, start + 1, i - start - 2, 0)
        } else {
            i = lex_operator(src, i, len, tokens)
        }
    }
    push_token(tokens, TOK_EOF, len, 0, 0)
}

// ---------------------------------------------------------------------------
// Token cursor. The parser reads token kinds through these rather than bytes.
// ---------------------------------------------------------------------------

peek_kind :: fn(mut p: Parser, offset: i64) -> i64 {
    index := p.ti + offset
    if (index >= p.tokens.count) {
        return TOK_EOF
    }
    entry : ^Token = arena_at(p.tokens, index)
    entry^.kind
}

cur :: fn(mut p: Parser) -> i64 {
    peek_kind(p, 0)
}

cur_off :: fn(mut p: Parser) -> i64 {
    entry : ^Token = arena_at(p.tokens, p.ti)
    entry^.off
}

cur_len :: fn(mut p: Parser) -> i64 {
    entry : ^Token = arena_at(p.tokens, p.ti)
    entry^.len
}

cur_val :: fn(mut p: Parser) -> i64 {
    entry : ^Token = arena_at(p.tokens, p.ti)
    entry^.value
}

advance :: fn(mut p: Parser) {
    p.ti = p.ti + 1
}

// ---------------------------------------------------------------------------
// Symbol tables. Identifiers are byte ranges into the source, interned to small
// integer indices by comparing bytes. Locals reset per function; functions are
// global.
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// Imports. `import "path"` names a file whose declarations join this one's.
// Every file's text reaches one buffer, so a name stays what it is everywhere
// else in this compiler, an offset and a length into a single source, and the
// rest of the compiler never learns that more than one file was involved.
//
// A file lands in the buffer once however many times it is named, which is what
// separates this from a textual include: the second `import` of a file is a
// reference to what is already there, not a second copy. Imports are found by
// token rather than by scanning the text, so the word `import` inside a string
// or a comment is not one.
// ---------------------------------------------------------------------------

module_seen :: fn(mut modules: Arena<Module>, path: ^i8) -> bool {
    mut i : i64 = 0
    while (i < modules.count) {
        entry : ^Module = arena_at(modules, i)
        if (cstr_eq(entry^.path, path)) {
            return true
        }
        i = i + 1
    }
    false
}

// A path named by an import, resolved against the directory of the file that
// named it.
join_path :: fn(parent: ^i8, src: ^i8, off: i64, len: i64) -> ^i8 {
    parent_len := frost_str_len(parent)
    mut cut : i64 = 0
    mut k : i64 = 0
    while (k < parent_len) {
        c := frost_byte_at(parent, k)
        if (c == CH_SLASH || c == CH_BACKSLASH) {
            cut = k + 1
        }
        k = k + 1
    }
    out := ptr_cast($i8, malloc(cut + len + 1))
    k = 0
    while (k < cut) {
        frost_byte_set(out, k, frost_byte_at(parent, k))
        k = k + 1
    }
    k = 0
    while (k < len) {
        frost_byte_set(out, cut + k, frost_byte_at(src, off + k))
        k = k + 1
    }
    frost_byte_set(out, cut + len, 0)
    out
}

// Copy a file's text into the buffer at `at`, terminated, and answer where the
// next one starts.
append_text :: fn(buffer: ^i8, at: i64, text: ^i8) -> i64 {
    length := frost_str_len(text)
    mut k : i64 = 0
    while (k < length) {
        frost_byte_set(buffer, at + k, frost_byte_at(text, k))
        k = k + 1
    }
    frost_byte_set(buffer, at + length, CH_LF)
    frost_byte_set(buffer, at + length + 1, 0)
    at + length + 1
}

// Place a file and everything it imports, imports first. A struct's name is
// resolved where it is written rather than looked up later, so a file has to
// reach the buffer after everything it depends on. A file already placed is
// skipped, which is what makes a diamond one copy and a cycle terminate.
place_module :: fn(buffer: ^i8, at: i64, path: ^i8, mut modules: Arena<Module>,
    mut scratch: Arena<Token>) -> i64 {
    if (module_seen(modules, path)) {
        return at
    }
    mine := arena_push(modules, Module { path = path, start = 0, finish = 0 })
    text := frost_read_file(path)
    if (frost_str_len(text) == 0) {
        frost_error("frost: cannot read '")
        frost_error(path)
        frost_error("'")
        frost_die()
    }
    // Read this file's imports out before recursing, since the recursion needs
    // the scratch tokens for the file it descends into.
    mut children := arena_make($Module, 256)
    scratch.count = 0
    tokenize(text, frost_str_len(text), scratch)
    mut i : i64 = 0
    while (i + 1 < scratch.count) {
        entry : ^Token = arena_at(scratch, i)
        named : ^Token = arena_at(scratch, i + 1)
        if (entry^.kind == TOK_KW_IMPORT && named^.kind == TOK_STR) {
            arena_push(
                children,
                Module { path = join_path(path, text, named^.off, named^.len),
                    start = 0, finish = 0 },
            )
        }
        i = i + 1
    }
    mut here := at
    mut c : i64 = 0
    while (c < children.count) {
        child : ^Module = arena_at(children, c)
        here = place_module(buffer, here, child^.path, modules, scratch)
        c = c + 1
    }
    finish := append_text(buffer, here, text)
    // The range is known only now, since everything this file imports went in
    // ahead of it. It is what tells a name which file wrote it.
    placed : ^Module = arena_at(modules, mine)
    placed^.start = here
    placed^.finish = finish
    finish
}

// Which module a byte belongs to. A program compiled from a single file has no
// modules recorded, and everything in it belongs to the root.
module_at :: fn(mut modules: Arena<Module>, offset: i64) -> i64 {
    mut i : i64 = 0
    while (i < modules.count) {
        entry : ^Module = arena_at(modules, i)
        if (offset >= entry^.start && offset < entry^.finish) {
            return i
        }
        i = i + 1
    }
    0
}

blank_range :: fn(buffer: ^i8, from: i64, through: i64) {
    mut b := from
    while (b <= through) {
        frost_byte_set(buffer, b, CH_SPACE)
        b = b + 1
    }
}

resolve_imports :: fn(buffer: ^i8, root: ^i8, names: ^i8,
    mut modules: Arena<Module>, mut exports: Arena<Export>,
    mut scratch: Arena<Token>) -> i64 {
    mut named_at : i64 = 0
    length := place_module(buffer, 0, root, modules, scratch)
    // Every imported file's text is in the buffer now, so the imports have
    // nothing left to say, and an export line has said it once it is recorded.
    // Blanking both leaves the parser one plain program with every offset where
    // it was.
    scratch.count = 0
    tokenize(buffer, length, scratch)
    mut j : i64 = 0
    while (j + 1 < scratch.count) {
        entry : ^Token = arena_at(scratch, j)
        named : ^Token = arena_at(scratch, j + 1)
        if (entry^.kind == TOK_KW_IMPORT && named^.kind == TOK_STR) {
            blank_range(buffer, entry^.off, named^.off + named^.len)
        }
        if (entry^.kind == TOK_KW_EXPORT) {
            owner := module_at(modules, entry^.off)
            mut k := j + 1
            mut through := entry^.off + entry^.len - 1
            mut listing : bool = true
            while (listing) {
                listed : ^Token = arena_at(scratch, k)
                if (listed^.kind != TOK_IDENT) {
                    listing = false
                } else {
                    // The name is copied out because the line it is written
                    // on is about to be blanked.
                    mut b : i64 = 0
                    while (b < listed^.len) {
                        frost_byte_set(names, named_at + b,
                            frost_byte_at(buffer, listed^.off + b))
                        b = b + 1
                    }
                    arena_push(
                        exports,
                        Export { module = owner, off = named_at,
                            len = listed^.len },
                    )
                    named_at = named_at + listed^.len
                    through = listed^.off + listed^.len - 1
                    k = k + 1
                    following : ^Token = arena_at(scratch, k)
                    if (following^.kind == TOK_COMMA) {
                        through = following^.off
                        k = k + 1
                    } else {
                        listing = false
                    }
                }
            }
            blank_range(buffer, entry^.off, through)
        }
        j = j + 1
    }
    scratch.count = 0
    length
}

// Room past the source's terminator for names the compiler makes up. A name is
// an offset and a length into the source everywhere in this compiler, so a
// synthesized one has to live in the source too rather than in a table of its
// own. The lexer stops at the terminator, so nothing here is ever read as code.
SYNTH_ROOM :: 65536

// Room for the root file and everything it imports, laid end to end.
SOURCE_ROOM :: 8388608

source_with_room :: fn(text: ^i8) -> ^i8 {
    length := frost_str_len(text)
    buffer := ptr_cast($i8, malloc(length + SYNTH_ROOM + 1))
    mut k : i64 = 0
    while (k < length) {
        frost_byte_set(buffer, k, frost_byte_at(text, k))
        k = k + 1
    }
    frost_byte_set(buffer, length, 0)
    buffer
}

// Copy a literal name into the room past the source and answer its offset, for
// a name the compiler needs that no source spells.
synth_literal :: fn(mut p: Parser, word: ^i8) -> i64 {
    start := p.synth_next
    length := frost_str_len(word)
    mut k : i64 = 0
    while (k < length) {
        frost_byte_set(p.src, start + k, frost_byte_at(word, k))
        k = k + 1
    }
    frost_byte_set(p.src, start + length, 0)
    p.synth_next = start + length + 1
    start
}

digits_in :: fn(number: i64) -> i64 {
    mut value := number
    mut digits : i64 = 1
    while (value >= 10) {
        value = value / 10
        digits = digits + 1
    }
    digits
}

// A name with a number after it, so each `?` and each failure set gets one of
// its own. Its length is the word's plus the number's digits.
synth_numbered :: fn(mut p: Parser, word: ^i8, number: i64) -> i64 {
    start := synth_literal(p, word)
    digits := digits_in(number)
    mut scale : i64 = 1
    mut left : i64 = 1
    while (left < digits) {
        scale = scale * 10
        left = left + 1
    }
    mut value := number
    mut written : i64 = 0
    while (written < digits) {
        digit := value / scale
        frost_byte_set(p.src, p.synth_next - 1 + written, CH_0 + digit)
        value = value - digit * scale
        scale = scale / 10
        written = written + 1
    }
    frost_byte_set(p.src, p.synth_next - 1 + digits, 0)
    p.synth_next = p.synth_next + digits
    start
}

// Two source names joined by an underscore, for a field that belongs to one
// variant of an enum: `Enemy` and `damage` become `Enemy_damage`. Two variants
// may each carry a `damage` and they stay apart.
synth_join :: fn(mut p: Parser, first_off: i64, first_len: i64, second_off: i64,
    second_len: i64) -> i64 {
    start := p.synth_next
    mut k : i64 = 0
    while (k < first_len) {
        frost_byte_set(p.src, start + k, frost_byte_at(p.src, first_off + k))
        k = k + 1
    }
    frost_byte_set(p.src, start + first_len, CH_UNDERSCORE)
    k = 0
    while (k < second_len) {
        frost_byte_set(p.src, start + first_len + 1 + k,
            frost_byte_at(p.src, second_off + k))
        k = k + 1
    }
    frost_byte_set(p.src, start + first_len + 1 + second_len, 0)
    p.synth_next = start + first_len + second_len + 2
    start
}

// The binding a `uses Arena` function draws: the capability type's name with
// its first letter lowercased, so `uses Arena<256>` binds `arena` and the body
// names it the way the caller's `with arena` block does.
synth_capability_name :: fn(mut p: Parser, off: i64, len: i64) -> i64 {
    start := p.synth_next
    mut k : i64 = 0
    while (k < len) {
        mut byte := frost_byte_at(p.src, off + k)
        if (k == 0 && byte >= CH_UPPER_A && byte <= CH_UPPER_Z) {
            byte = byte + 32
        }
        frost_byte_set(p.src, start + k, byte)
        k = k + 1
    }
    frost_byte_set(p.src, start + len, 0)
    p.synth_next = start + len + 1
    start
}

// The same comparison across two buffers, for a name kept somewhere other than
// the source it was read from.
bytes_equal_across :: fn(first: ^i8, first_off: i64, second: ^i8,
    second_off: i64, length: i64) -> bool {
    mut k : i64 = 0
    while (k < length) {
        if (frost_byte_at(first, first_off + k)
            != frost_byte_at(second, second_off + k)) {
            return false
        }
        k = k + 1
    }
    true
}

bytes_equal :: fn(src: ^i8, first: i64, second: i64, length: i64) -> bool {
    mut k : i64 = 0
    while (k < length) {
        if (frost_byte_at(src, first + k) != frost_byte_at(src, second + k)) {
            return false
        }
        k = k + 1
    }
    true
}

intern_global :: fn(mut p: Parser, offset: i64, length: i64) -> i64 {
    mut i : i64 = 0
    while (i < p.fns.count) {
        entry : ^Sym = arena_at(p.fns, i)
        if (entry^.len == length
            && bytes_equal(p.src, entry^.off, offset, length)
            && name_visible(p, entry^.off, entry^.len, offset)) {
            return i
        }
        i = i + 1
    }
    arena_push(
        p.fns,
        Sym { off = offset, len = length, is_extern = 0, ret_type = TY_I64,
            params = 0 - 1, defined = 0, uses_ty = 0 - 1, cap_off = 0,
            cap_len = 0 },
    )
}

// A name becomes defined when its `fn` or `extern fn` is parsed. A name that is
// only ever called is interned but never defined, which is a call to a function
// that does not exist.
mark_defined :: fn(mut p: Parser, fn_index: i64) {
    entry : ^Sym = arena_at(p.fns, fn_index)
    entry^.defined = 1
}

mark_extern :: fn(mut p: Parser, fn_index: i64) {
    entry : ^Sym = arena_at(p.fns, fn_index)
    entry^.is_extern = 1
}

set_ret_type :: fn(mut p: Parser, fn_index: i64, ret: i64) {
    entry : ^Sym = arena_at(p.fns, fn_index)
    entry^.ret_type = ret
}

set_params :: fn(mut p: Parser, fn_index: i64, params: i64) {
    entry : ^Sym = arena_at(p.fns, fn_index)
    entry^.params = params
}

set_uses :: fn(mut p: Parser, fn_index: i64, ty: i64, off: i64, len: i64) {
    entry : ^Sym = arena_at(p.fns, fn_index)
    entry^.uses_ty = ty
    entry^.cap_off = off
    entry^.cap_len = len
}

node_next :: fn(mut p: Parser, id: i64) -> i64 {
    node : ^Node = arena_at(p.arena, id)
    node^.next
}

append_node :: fn(mut p: Parser, head: i64, extra: i64) -> i64 {
    if (head == (0 - 1)) {
        return extra
    }
    mut tail := head
    mut following := node_next(p, tail)
    while (following != (0 - 1)) {
        tail = following
        following = node_next(p, tail)
    }
    set_next(p, tail, extra)
    head
}

record_generic_fn :: fn(mut p: Parser, fn_index: i64, tparam_off: i64,
    tparam_len: i64, token_start: i64) {
    arena_push(
        p.generic_fns,
        GenericFn { fn_index = fn_index, tparam_off = tparam_off,
            tparam_len = tparam_len, token_start = token_start },
    )
}

// Register `name :: value` in the constant table. Duplicate names are harmless
// since lookup takes the first.
register_const :: fn(mut p: Parser, offset: i64, length: i64, value: i64) {
    arena_push(
        p.consts,
        ConstDef { name_off = offset, name_len = length, value = value },
    )
}

// Whether a declaration whose name sits at `decl_off` may be named from
// `use_off`. A file's own names are its own to use; another file's are only
// what it exported. The declaration's offset is what says which file wrote it,
// so no table has to carry an owner.
//
// A program compiled from one file has one module and every name is in it, so
// this answers true on the first comparison and costs nothing.
name_visible :: fn(mut p: Parser, decl_off: i64, decl_len: i64, use_off: i64)
    -> bool {
    owner := module_at(p.modules, decl_off)
    if (owner == module_at(p.modules, use_off)) {
        return true
    }
    mut i : i64 = 0
    while (i < p.exports.count) {
        entry : ^Export = arena_at(p.exports, i)
        if (entry^.module == owner && entry^.len == decl_len
            && bytes_equal_across(p.export_names, entry^.off, p.src, decl_off,
                decl_len)) {
            return true
        }
        i = i + 1
    }
    false
}

// If a name is a declared constant, return its value through `out` (as the
// return) and true; otherwise false. Consts are looked up by byte comparison.
const_value :: fn(mut p: Parser, offset: i64, length: i64) -> i64 {
    mut i : i64 = 0
    while (i < p.consts.count) {
        entry : ^ConstDef = arena_at(p.consts, i)
        if (entry^.name_len == length
            && bytes_equal(p.src, entry^.name_off, offset, length)
            && name_visible(p, entry^.name_off, entry^.name_len, offset)) {
            return entry^.value
        }
        i = i + 1
    }
    0 - 1
}

is_const :: fn(mut p: Parser, offset: i64, length: i64) -> bool {
    mut i : i64 = 0
    while (i < p.consts.count) {
        entry : ^ConstDef = arena_at(p.consts, i)
        if (entry^.name_len == length
            && bytes_equal(p.src, entry^.name_off, offset, length)
            && name_visible(p, entry^.name_off, entry^.name_len, offset)) {
            return true
        }
        i = i + 1
    }
    false
}

is_main_name :: fn(src: ^i8, offset: i64, length: i64) -> bool {
    if (length != 4) {
        return false
    }
    frost_byte_at(src, offset) == 109 && frost_byte_at(src, offset + 1) == 97
        && frost_byte_at(src, offset + 2) == 105
        && frost_byte_at(src, offset + 3) == 110
}

// ---------------------------------------------------------------------------
// Parsing.
// ---------------------------------------------------------------------------

new_node :: fn(mut p: Parser, kind: i64, a: i64, b: i64, val: i64) -> i64 {
    arena_push(
        p.arena,
        Node { kind = kind, a = a, b = b, c = 0, val = val, next = 0 - 1 },
    )
}

// A node that names a local by its source byte range: `val` is the offset and
// `c` is the length, so code generation re-emits the identifier text directly.
// This is what lets locals become named C variables instead of `v[]` slots.
new_named_node :: fn(mut p: Parser, kind: i64, child: i64, offset: i64,
    length: i64) -> i64 {
    arena_push(
        p.arena,
        Node { kind = kind, a = child, b = 0, c = length, val = offset,
            next = 0 - 1 },
    )
}

// A local binding. `b` carries the annotated type, or -1 to infer the type from
// the initializer. An annotation wins because a generic call cannot be typed
// precisely from the callee alone (`entry : ^Token = arena_at(...)`).
new_let_node :: fn(mut p: Parser, value: i64, offset: i64, length: i64,
    annotation: i64) -> i64 {
    arena_push(
        p.arena,
        Node { kind = NODE_LET, a = value, b = annotation, c = length,
            val = offset, next = 0 - 1 },
    )
}

new_func_node :: fn(mut p: Parser, body: i64, params: i64, fn_index: i64,
    is_main: i64) -> i64 {
    arena_push(
        p.arena,
        Node {
            kind = NODE_FUNC,
            a = body,
            b = params,
            c = is_main,
            val = fn_index,
            next = 0 - 1,
        },
    )
}

set_next :: fn(mut p: Parser, id: i64, next_id: i64) {
    node : ^Node = arena_at(p.arena, id)
    node^.next = next_id
}

// A field access `base.name`: `a` is the base expression, `val`/`c` the field
// name's byte range.
new_field_node :: fn(mut p: Parser, base: i64, offset: i64, length: i64) -> i64 {
    arena_push(
        p.arena,
        Node { kind = NODE_FIELD, a = base, b = 0, c = length, val = offset,
            next = 0 - 1 },
    )
}

// A struct literal `Name { ... }`: `val` is the struct's table index and `a` is
// the head of a linked list of NODE_FIELD_INIT nodes.
new_struct_lit :: fn(mut p: Parser, struct_index: i64, inits: i64) -> i64 {
    arena_push(
        p.arena,
        Node { kind = NODE_STRUCT_LIT, a = inits, b = 0, c = 0,
            val = struct_index, next = 0 - 1 },
    )
}

// One `name = value` inside a struct literal: `a` is the value, `val`/`c` the
// field name's byte range, `next` the following initializer.
new_field_init :: fn(mut p: Parser, value: i64, offset: i64, length: i64) -> i64 {
    arena_push(
        p.arena,
        Node { kind = NODE_FIELD_INIT, a = value, b = 0, c = length,
            val = offset, next = 0 - 1 },
    )
}

set_field_next :: fn(mut p: Parser, id: i64, next_id: i64) {
    field : ^StructField = arena_at(p.fields, id)
    field^.next = next_id
}

is_pointer :: fn(ty: i64) -> bool {
    ty >= POINTER_BASE
}

pointee :: fn(ty: i64) -> i64 {
    ty - POINTER_BASE
}

is_struct_ty :: fn(ty: i64) -> bool {
    ty >= STRUCT_BASE && ty < POINTER_BASE
}

struct_index_of :: fn(ty: i64) -> i64 {
    ty - STRUCT_BASE
}

// Resolve a type name (byte range) to a type code: the current generic type
// parameter (bound to its concrete type while monomorphizing, otherwise the
// TY_PARAM placeholder), a primitive keyword, or the named struct. A generic
// template struct is not returned here; `Name<Arg>` instantiation is handled in
// parse_type. An unknown name falls back to i64.
type_code_for :: fn(mut p: Parser, offset: i64, length: i64) -> i64 {
    if (p.type_param_len == length
        && bytes_equal(p.src, p.type_param_off, offset, length)) {
        if (p.binding_active == 1) {
            return p.type_binding
        }
        return TY_PARAM
    }
    if (str_range_eq(p.src, offset, length, "i64")) { return TY_I64 }
    if (str_range_eq(p.src, offset, length, "i8")) { return TY_I8 }
    if (str_range_eq(p.src, offset, length, "u8")) { return TY_U8 }
    if (str_range_eq(p.src, offset, length, "bool")) { return TY_BOOL }
    mut i : i64 = 0
    while (i < p.structs.count) {
        entry : ^StructDef = arena_at(p.structs, i)
        if (entry^.is_generic == 0 && entry^.name_len == length
            && bytes_equal(p.src, entry^.name_off, offset, length)
            && name_visible(p, entry^.name_off, entry^.name_len, offset)) {
            return STRUCT_BASE + i
        }
        i = i + 1
    }
    TY_I64
}

// Find the index of a generic struct template by name, or -1.
generic_index_for :: fn(mut p: Parser, offset: i64, length: i64) -> i64 {
    mut i : i64 = 0
    while (i < p.structs.count) {
        entry : ^StructDef = arena_at(p.structs, i)
        if (entry^.is_generic == 1 && entry^.name_len == length
            && bytes_equal(p.src, entry^.name_off, offset, length)
            && name_visible(p, entry^.name_off, entry^.name_len, offset)) {
            return i
        }
        i = i + 1
    }
    0 - 1
}

// A unary node wrapping a single child expression (deref, address-of).
new_unary :: fn(mut p: Parser, kind: i64, child: i64) -> i64 {
    arena_push(
        p.arena,
        Node { kind = kind, a = child, b = 0, c = 0, val = 0, next = 0 - 1 },
    )
}

// An index node `base[index]`: `a` is the base, `b` the index expression.
new_index :: fn(mut p: Parser, base: i64, index: i64) -> i64 {
    arena_push(
        p.arena,
        Node { kind = NODE_INDEX, a = base, b = index, c = 0, val = 0,
            next = 0 - 1 },
    )
}

// A node carrying a type code in `val` (ptr_cast target, sizeof operand) and an
// optional expression in `a`.
new_type_node :: fn(mut p: Parser, kind: i64, expr: i64, ty: i64) -> i64 {
    arena_push(
        p.arena,
        Node { kind = kind, a = expr, b = 0, c = 0, val = ty, next = 0 - 1 },
    )
}

// One arm of a match: `a` is the body statement, `val` the integer pattern, and
// `c` a flag marking the `_` default arm.
new_case :: fn(mut p: Parser, body: i64, value: i64, is_default: i64) -> i64 {
    arena_push(
        p.arena,
        Node { kind = NODE_CASE, a = body, b = 0, c = is_default, val = value,
            next = 0 - 1 },
    )
}

parse_number :: fn(mut p: Parser) -> i64 {
    value := cur_val(p)
    advance(p)
    new_node(p, NODE_NUM, 0, 0, value)
}

parse_primary :: fn(mut p: Parser) -> i64 {
    kind := cur(p)
    if (kind == TOK_INT) {
        return parse_number(p)
    }
    if (kind == TOK_KW_TRUE) {
        advance(p)
        return new_node(p, NODE_NUM, 0, 0, 1)
    }
    if (kind == TOK_KW_FALSE) {
        advance(p)
        return new_node(p, NODE_NUM, 0, 0, 0)
    }
    if (kind == TOK_STR) {
        offset := cur_off(p)
        length := cur_len(p)
        advance(p)
        return new_named_node(p, NODE_STRLIT, 0, offset, length)
    }
    if (kind == TOK_DOLLAR) {
        advance(p)
        ty := parse_type(p)
        return new_type_node(p, NODE_TYPEVAL, 0, ty)
    }
    // A match used where a value is wanted: bind a name, let each arm assign to
    // it, and stand for the name. The match itself is queued for the block,
    // which is the same road a `?` takes.
    if (kind == TOK_KW_MATCH) {
        name_off := synth_numbered(p, "__value", p.match_count)
        name_len := 7 + digits_in(p.match_count)
        p.match_count = p.match_count + 1
        seed := new_node(p, NODE_NUM, 0, 0, 0)
        bind := new_let_node(p, seed, name_off, name_len, 0 - 1)
        chosen := parse_match(p)
        assign_case_values(p, chosen, name_off, name_len)
        arena_push(p.pending, LocalVar { name_off = bind, name_len = chosen,
            ty = 0 })
        return new_named_node(p, NODE_VAR, 0, name_off, name_len)
    }
    if (kind == TOK_LPAREN) {
        advance(p)
        inner := parse_expr(p)
        advance(p)
        return inner
    }
    offset := cur_off(p)
    length := cur_len(p)
    advance(p)
    // `Kind::Enemy { ... }` names a variant of an enum.
    if (cur(p) == TOK_COLONCOLON) {
        advance(p)
        return parse_variant_value(p, offset, length)
    }
    if (cur(p) == TOK_LPAREN) {
        if (str_range_eq(p.src, offset, length, "ptr_to")) {
            advance(p)
            inner := parse_expr(p)
            advance(p)
            return new_unary(p, NODE_ADDROF, inner)
        }
        if (str_range_eq(p.src, offset, length, "sizeof")) {
            advance(p)
            ty := parse_type(p)
            advance(p)
            return new_type_node(p, NODE_SIZEOF, 0, ty)
        }
        if (str_range_eq(p.src, offset, length, "ptr_cast")) {
            advance(p)
            if (cur(p) == TOK_DOLLAR) {
                advance(p)
            }
            ty := parse_type(p)
            advance(p)
            expr := parse_expr(p)
            advance(p)
            return new_type_node(p, NODE_PTR_CAST, expr, ty)
        }
        advance(p)
        args := parse_arg_list(p)
        fn_index := intern_global(p, offset, length)
        return new_node(p, NODE_CALL, args, 0, fn_index)
    }
    if (cur(p) == TOK_LBRACE && p.no_struct_lit == false) {
        struct_ty := resolve_lit_type(p, offset, length)
        advance(p)
        inits := parse_field_inits(p)
        return new_struct_lit(p, struct_ty, inits)
    }
    new_named_node(p, NODE_VAR, 0, offset, length)
}

// The struct type for a literal `Name { ... }`. A generic name resolves, under
// an active binding, to the instance for the bound type argument; that is how the
// bare `Arena { ... }` inside a generic function names the right instance.
resolve_lit_type :: fn(mut p: Parser, offset: i64, length: i64) -> i64 {
    gi := generic_index_for(p, offset, length)
    if (gi >= 0) {
        if (p.binding_active == 1) {
            return instantiate(p, gi, p.type_binding)
        }
        return TY_I64
    }
    type_code_for(p, offset, length)
}

// Apply any trailing `.field`, `^` deref, and `[index]` operators to a node.
// `e?` where the enclosing function answers with a failure set: bind the
// result, hand the failure on if that is what it holds, and stand for the value
// otherwise. The three statements are queued for the block being parsed, which
// is what lets a `?` sit anywhere an expression can rather than only where a
// statement can.
lower_try :: fn(mut p: Parser, value: i64) -> i64 {
    if (p.result_ty == (0 - 1)) {
        frost_error("frost: '?' needs a function that declares a failure set")
        frost_die()
    }
    name_off := synth_numbered(p, "__try", p.try_count)
    name_len := 5 + digits_in(p.try_count)
    p.try_count = p.try_count + 1

    bind := new_let_node(p, value, name_off, name_len, 0 - 1)
    held := new_named_node(p, NODE_VAR, 0, name_off, name_len)
    tag := new_field_node(p, held, p.name_tag, 3)
    zero := new_node(p, NODE_NUM, 0, 0, 0)
    failed := new_node(p, NODE_BIN, tag, zero, OP_NE)
    carried := new_field_node(
        p,
        new_named_node(p, NODE_VAR, 0, name_off, name_len),
        p.name_error,
        5,
    )
    hand_on := new_node(
        p,
        NODE_RETURN,
        new_result_value(p, p.result_ty, 1, p.name_error, 5, carried),
        0,
        0,
    )
    guard := new_node(p, NODE_IF, failed, hand_on, 0 - 1)
    arena_push(p.pending, LocalVar { name_off = bind, name_len = guard, ty = 0 })
    new_field_node(
        p,
        new_named_node(p, NODE_VAR, 0, name_off, name_len),
        p.name_value,
        5,
    )
}

// A body's last expression is its answer, so in a fallible function that value
// is the ok side of the failure set just as an explicit `return` is.
wrap_trailing_ok :: fn(mut p: Parser, body: i64) {
    if (body == (0 - 1)) {
        return
    }
    mut id := body
    mut last := body
    while (id != (0 - 1)) {
        last = id
        id = node_next(p, id)
    }
    node : ^Node = arena_at(p.arena, last)
    if (node^.kind == NODE_EXPRSTMT) {
        node^.a = wrap_result(p, node^.a)
    }
}

parse_postfix :: fn(mut p: Parser, start: i64) -> i64 {
    mut node := start
    while (cur(p) == TOK_DOT || cur(p) == TOK_CARET
        || cur(p) == TOK_QUESTION || cur(p) == TOK_LBRACKET) {
        if (cur(p) == TOK_QUESTION) {
            advance(p)
            node = lower_try(p, node)
        } else if (cur(p) == TOK_DOT) {
            advance(p)
            offset := cur_off(p)
            length := cur_len(p)
            advance(p)
            node = new_field_node(p, node, offset, length)
        } else if (cur(p) == TOK_CARET) {
            advance(p)
            node = new_unary(p, NODE_DEREF, node)
        } else {
            advance(p)
            index := parse_expr(p)
            advance(p)
            node = new_index(p, node, index)
        }
    }
    node
}

parse_factor :: fn(mut p: Parser) -> i64 {
    parse_postfix(p, parse_primary(p))
}

parse_field_inits :: fn(mut p: Parser) -> i64 {
    mut head : i64 = 0 - 1
    mut tail : i64 = 0 - 1
    while (cur(p) != TOK_RBRACE && cur(p) != TOK_EOF) {
        offset := cur_off(p)
        length := cur_len(p)
        advance(p)
        advance(p)
        value := parse_expr(p)
        init := new_field_init(p, value, offset, length)
        if (head == (0 - 1)) {
            head = init
            tail = init
        } else {
            set_next(p, tail, init)
            tail = init
        }
        if (cur(p) == TOK_COMMA) {
            advance(p)
        }
    }
    advance(p)
    head
}

parse_arg_list :: fn(mut p: Parser) -> i64 {
    mut head : i64 = 0 - 1
    mut tail : i64 = 0 - 1
    while (cur(p) != TOK_RPAREN && cur(p) != TOK_EOF) {
        value := parse_expr(p)
        arg := new_node(p, NODE_ARG, value, 0, 0)
        if (head == (0 - 1)) {
            head = arg
            tail = arg
        } else {
            set_next(p, tail, arg)
            tail = arg
        }
        if (cur(p) == TOK_COMMA) {
            advance(p)
        }
    }
    advance(p)
    head
}

parse_mul :: fn(mut p: Parser) -> i64 {
    mut left := parse_factor(p)
    mut kind := cur(p)
    while (kind == TOK_STAR || kind == TOK_SLASH || kind == TOK_PERCENT) {
        mut op : i64 = OP_MUL
        if (kind == TOK_SLASH) {
            op = OP_DIV
        }
        if (kind == TOK_PERCENT) {
            op = OP_MOD
        }
        advance(p)
        right := parse_factor(p)
        left = new_node(p, NODE_BIN, left, right, op)
        kind = cur(p)
    }
    left
}

parse_add :: fn(mut p: Parser) -> i64 {
    mut left := parse_mul(p)
    mut kind := cur(p)
    while (kind == TOK_PLUS || kind == TOK_MINUS) {
        mut op : i64 = OP_ADD
        if (kind == TOK_MINUS) {
            op = OP_SUB
        }
        advance(p)
        right := parse_mul(p)
        left = new_node(p, NODE_BIN, left, right, op)
        kind = cur(p)
    }
    left
}

parse_cmp :: fn(mut p: Parser) -> i64 {
    left := parse_add(p)
    kind := cur(p)
    if (kind == TOK_LT) {
        advance(p)
        right := parse_add(p)
        return new_node(p, NODE_BIN, left, right, OP_LT)
    }
    if (kind == TOK_LE) {
        advance(p)
        right := parse_add(p)
        return new_node(p, NODE_BIN, left, right, OP_LE)
    }
    if (kind == TOK_GT) {
        advance(p)
        right := parse_add(p)
        return new_node(p, NODE_BIN, left, right, OP_GT)
    }
    if (kind == TOK_GE) {
        advance(p)
        right := parse_add(p)
        return new_node(p, NODE_BIN, left, right, OP_GE)
    }
    if (kind == TOK_EQEQ) {
        advance(p)
        right := parse_add(p)
        return new_node(p, NODE_BIN, left, right, OP_EQ)
    }
    if (kind == TOK_NE) {
        advance(p)
        right := parse_add(p)
        return new_node(p, NODE_BIN, left, right, OP_NE)
    }
    left
}

parse_and :: fn(mut p: Parser) -> i64 {
    mut left := parse_cmp(p)
    while (cur(p) == TOK_ANDAND) {
        advance(p)
        right := parse_cmp(p)
        left = new_node(p, NODE_BIN, left, right, OP_AND)
    }
    left
}

parse_expr :: fn(mut p: Parser) -> i64 {
    mut left := parse_and(p)
    while (cur(p) == TOK_OROR) {
        advance(p)
        right := parse_and(p)
        left = new_node(p, NODE_BIN, left, right, OP_OR)
    }
    left
}

parse_block :: fn(mut p: Parser) -> i64 {
    advance(p)
    head := parse_stmt_list(p, TOK_RBRACE)
    advance(p)
    head
}

// Parse a type and return its type code. Each pointer prefix adds a pointer
// level (a borrow is a C pointer). A leading `$` marks a type
// parameter; if none is bound yet in the current generic, this use establishes
// it. `Generic<Arg>` instantiates the generic struct to a concrete one. A `<...>`
// on a non-generic name is consumed and treated as i64.
parse_type :: fn(mut p: Parser) -> i64 {
    mut pointer_levels : i64 = 0
    while (cur(p) == TOK_CARET) {
        advance(p)
        pointer_levels = pointer_levels + 1
    }
    mut dollar : i64 = 0
    if (cur(p) == TOK_DOLLAR) {
        advance(p)
        dollar = 1
    }
    offset := cur_off(p)
    length := cur_len(p)
    advance(p)
    if (dollar == 1 && p.type_param_len == 0) {
        p.type_param_off = offset
        p.type_param_len = length
        p.saw_type_param = 1
    }
    mut base : i64 = TY_I64
    mut was_generic : i64 = 0
    if (cur(p) == TOK_LT) {
        was_generic = 1
        gi := generic_index_for(p, offset, length)
        advance(p)
        arg := parse_type(p)
        advance(p)
        // Only instantiate for a concrete argument. While parsing a generic
        // template the argument is the TY_PARAM placeholder, and that instance
        // is created later with the parameter bound to a real type.
        if (gi >= 0 && arg != TY_PARAM) {
            base = instantiate(p, gi, arg)
        }
    } else {
        base = type_code_for(p, offset, length)
        if (base == TY_PARAM) {
            p.saw_type_param = 1
        }
    }
    // Record whether this type named a generic-struct instance, so parse_params
    // can tell a `Foo<T>` template placeholder (which collapses to a scalar code)
    // apart from a real scalar and still borrow it by pointer.
    p.last_type_was_generic = was_generic
    mut result := base
    mut k : i64 = 0
    while (k < pointer_levels) {
        result = POINTER_BASE + result
        k = k + 1
    }
    result
}

parse_type_annotation :: fn(mut p: Parser) -> i64 {
    advance(p)
    parse_type(p)
}

// Parse `{ field : Type, ... }` into a linked list of fields, returning the head.
// Field types resolve under any active type-parameter binding.
parse_struct_fields :: fn(mut p: Parser) -> i64 {
    advance(p)
    mut head : i64 = 0 - 1
    mut tail : i64 = 0 - 1
    while (cur(p) != TOK_RBRACE && cur(p) != TOK_EOF) {
        field_offset := cur_off(p)
        field_length := cur_len(p)
        advance(p)
        field_ty := parse_type_annotation(p)
        field := arena_push(
            p.fields,
            StructField { name_off = field_offset, name_len = field_length,
                ty = field_ty, next = 0 - 1 },
        )
        if (head == (0 - 1)) {
            head = field
            tail = field
        } else {
            set_field_next(p, tail, field)
            tail = field
        }
        if (cur(p) == TOK_COMMA) {
            advance(p)
        }
    }
    advance(p)
    head
}

// Get or create the concrete struct for a generic instantiation. The template's
// fields are re-parsed with the type parameter bound to `arg`, producing a new
// struct whose emitted name is `<generic>_<index>`.
instantiate :: fn(mut p: Parser, generic_index: i64, arg: i64) -> i64 {
    mut i : i64 = 0
    while (i < p.instances.count) {
        entry : ^Instance = arena_at(p.instances, i)
        if (entry^.generic_index == generic_index && entry^.arg == arg) {
            return STRUCT_BASE + entry^.struct_index
        }
        i = i + 1
    }
    template : ^StructDef = arena_at(p.structs, generic_index)
    name_off := template^.name_off
    name_len := template^.name_len
    tparam_off := template^.tparam_off
    tparam_len := template^.tparam_len
    field_token := template^.field_token

    saved_ti := p.ti
    saved_param_off := p.type_param_off
    saved_param_len := p.type_param_len
    saved_binding := p.type_binding
    saved_active := p.binding_active
    p.type_param_off = tparam_off
    p.type_param_len = tparam_len
    p.type_binding = arg
    p.binding_active = 1
    p.ti = field_token
    field_head := parse_struct_fields(p)
    p.ti = saved_ti
    p.type_param_off = saved_param_off
    p.type_param_len = saved_param_len
    p.type_binding = saved_binding
    p.binding_active = saved_active

    struct_index := p.structs.count
    arena_push(
        p.structs,
        StructDef { name_off = name_off, name_len = name_len,
            field_head = field_head, is_generic = 0, tparam_off = 0,
            tparam_len = 0, field_token = 0, instance_id = struct_index,
            is_linear = 0 },
    )
    arena_push(
        p.instances,
        Instance { generic_index = generic_index, arg = arg,
            struct_index = struct_index },
    )
    STRUCT_BASE + struct_index
}

// A match `match expr { case N: stmt  case _: stmt }`. The scrutinee is parsed
// with struct literals suppressed so the `{` opening the arms is not mistaken
// for one. Each arm holds a single statement.
// `case .Enemy { damage }:` matches the tag and binds each named field from the
// variant's own field in the scrutinee. The bindings are ordinary lets at the
// top of the arm, so the body sees them as it would any local.
parse_variant_case :: fn(mut p: Parser, subject: i64) -> i64 {
    variant_off := cur_off(p)
    variant_len := cur_len(p)
    advance(p)
    index := find_variant(p, 0 - 1, variant_off, variant_len)
    if (index < 0) {
        frost_error("frost: no enum has a variant '")
        frost_error_src(p.src, variant_off, variant_len)
        frost_error("'")
        frost_die()
    }
    entry : ^Variant = arena_at(p.variants, index)
    tag := entry^.tag
    mut bindings : i64 = 0 - 1
    mut tail : i64 = 0 - 1
    if (cur(p) == TOK_LBRACE) {
        advance(p)
        while (cur(p) != TOK_RBRACE && cur(p) != TOK_EOF) {
            field_off := cur_off(p)
            field_len := cur_len(p)
            advance(p)
            qualified := synth_join(p, variant_off, variant_len, field_off,
                field_len)
            read := new_field_node(p, subject, qualified,
                variant_len + field_len + 1)
            bind := new_let_node(p, read, field_off, field_len, 0 - 1)
            if (bindings == (0 - 1)) {
                bindings = bind
            } else {
                set_next(p, tail, bind)
            }
            tail = bind
            if (cur(p) == TOK_COMMA) {
                advance(p)
            }
        }
        advance(p)
    }
    advance(p)
    body := parse_arm(p)
    if (bindings == (0 - 1)) {
        return new_case(p, body, tag, 0)
    }
    set_next(p, tail, body)
    new_case(p, bindings, tag, 0)
}

// Turn each arm's trailing expression into an assignment to the name standing
// for the match's value. An arm that already does something else is left as it
// is, since it was not producing a value in the first place.
assign_case_values :: fn(mut p: Parser, match_node: i64, name_off: i64,
    name_len: i64) {
    node : ^Node = arena_at(p.arena, match_node)
    mut cid := node^.b
    while (cid != (0 - 1)) {
        case_node : ^Node = arena_at(p.arena, cid)
        mut last := case_node^.a
        mut following := node_next(p, last)
        while (following != (0 - 1)) {
            last = following
            following = node_next(p, last)
        }
        body : ^Node = arena_at(p.arena, last)
        // An arm that ends in something with no value, a call to a void
        // function say, was never producing one, so it is left as it is.
        if (body^.kind == NODE_EXPRSTMT && type_of(p, body^.a) != TY_VOID) {
            place := new_named_node(p, NODE_VAR, 0, name_off, name_len)
            body^.kind = NODE_ASSIGN
            body^.b = body^.a
            body^.a = place
        }
        cid = case_node^.next
    }
}

parse_match :: fn(mut p: Parser) -> i64 {
    advance(p)
    p.no_struct_lit = true
    mut scrutinee := parse_expr(p)
    p.no_struct_lit = false
    advance(p)
    // A variant pattern matches on which variant the value holds, so the thing
    // switched on is the tag rather than the value itself. The value is bound
    // first, since the arms read fields out of it too.
    mut subject : i64 = 0 - 1
    if (peek_kind(p, 1) == TOK_DOT) {
        name_off := synth_numbered(p, "__match", p.match_count)
        name_len := 7 + digits_in(p.match_count)
        p.match_count = p.match_count + 1
        bind := new_let_node(p, scrutinee, name_off, name_len, 0 - 1)
        arena_push(p.pending, LocalVar { name_off = bind, name_len = bind,
            ty = 0 })
        subject = new_named_node(p, NODE_VAR, 0, name_off, name_len)
        scrutinee = new_field_node(p, subject, p.name_tag, 3)
    }
    mut head : i64 = 0 - 1
    mut tail : i64 = 0 - 1
    while (cur(p) != TOK_RBRACE && cur(p) != TOK_EOF) {
        advance(p)
        mut is_default : i64 = 0
        mut value : i64 = 0
        mut case_node : i64 = 0 - 1
        if (cur(p) == TOK_DOT) {
            advance(p)
            case_node = parse_variant_case(p, subject)
        } else {
            if (cur(p) == TOK_INT) {
                value = cur_val(p)
                advance(p)
            } else {
                is_default = 1
                advance(p)
            }
            advance(p)
            body := parse_arm(p)
            case_node = new_case(p, body, value, is_default)
        }
        if (head == (0 - 1)) {
            head = case_node
            tail = case_node
        } else {
            set_next(p, tail, case_node)
            tail = case_node
        }
    }
    advance(p)
    new_node(p, NODE_MATCH, scrutinee, head, 0)
}

parse_stmt :: fn(mut p: Parser) -> i64 {
    kind := cur(p)

    if (kind == TOK_KW_MUT) {
        advance(p)
        offset := cur_off(p)
        length := cur_len(p)
        advance(p)
        mut ann : i64 = 0 - 1
        if (cur(p) == TOK_COLON) {
            ann = parse_type_annotation(p)
            advance(p)
        } else {
            advance(p)
        }
        value := parse_expr(p)
        return new_let_node(p, value, offset, length, ann)
    }
    if (kind == TOK_KW_PRINT) {
        advance(p)
        value := parse_expr(p)
        return new_node(p, NODE_PRINT, value, 0, 0)
    }
    if (kind == TOK_KW_RETURN) {
        advance(p)
        if (cur(p) == TOK_RBRACE) {
            return new_node(p, NODE_RETURN, 0 - 1, 0, 0)
        }
        mut value := parse_expr(p)
        if (p.result_ty != (0 - 1)) {
            value = wrap_result(p, value)
        }
        return new_node(p, NODE_RETURN, value, 0, 0)
    }
    if (kind == TOK_KW_IF) {
        advance(p)
        advance(p)
        condition := parse_expr(p)
        advance(p)
        then_head := parse_block(p)
        mut else_head : i64 = 0 - 1
        if (cur(p) == TOK_KW_ELSE) {
            advance(p)
            if (cur(p) == TOK_KW_IF) {
                else_head = parse_stmt(p)
            } else {
                else_head = parse_block(p)
            }
        }
        return new_node(p, NODE_IF, condition, then_head, else_head)
    }
    if (kind == TOK_KW_WHILE) {
        advance(p)
        advance(p)
        // Anything the condition needs set up, a `?` or a match used as a
        // value, belongs to the loop rather than to the statement before it,
        // since the condition is asked again every time round.
        mark := p.pending.count
        condition := parse_expr(p)
        preamble := flush_pending(p, mark, 0 - 1)
        advance(p)
        body := parse_block(p)
        loop := new_node(p, NODE_WHILE, condition, body, 0)
        set_while_preamble(p, loop, preamble)
        return loop
    }
    // `with arena { ... }` supplies an allocation capability to everything the
    // block calls. The block is the region: it is a plain scope once the calls
    // inside it have been handed the arena.
    if (kind == TOK_KW_WITH) {
        advance(p)
        name_offset := cur_off(p)
        name_length := cur_len(p)
        advance(p)
        body := parse_block(p)
        return new_named_node(p, NODE_WITH, body, name_offset, name_length)
    }

    // A local binding `x := e` or `x : T = e` is recognised by the token after
    // the name, so the name is not consumed early for the other cases.
    if (cur(p) == TOK_IDENT && peek_kind(p, 1) == TOK_COLONEQ) {
        offset := cur_off(p)
        length := cur_len(p)
        advance(p)
        advance(p)
        value := parse_expr(p)
        return new_let_node(p, value, offset, length, 0 - 1)
    }
    if (cur(p) == TOK_IDENT && peek_kind(p, 1) == TOK_COLON) {
        offset := cur_off(p)
        length := cur_len(p)
        advance(p)
        ann := parse_type_annotation(p)
        advance(p)
        value := parse_expr(p)
        return new_let_node(p, value, offset, length, ann)
    }

    // Otherwise the statement starts with a full expression. If `=` follows it is
    // an assignment to that place; otherwise it is an expression statement (a
    // call). This is how `p.x = e`, `node^.next = e`, and `close(f)` are handled.
    expr := parse_expr(p)
    if (cur(p) == TOK_ASSIGN) {
        advance(p)
        value := parse_expr(p)
        return new_node(p, NODE_ASSIGN, expr, value, 0)
    }
    new_unary(p, NODE_EXPRSTMT, expr)
}

// Everything a `?` or a match queued while this statement was being parsed goes
// in ahead of it, in the order it was written. Each queued entry is a run of
// one or two statements, given by its first and last.
flush_pending :: fn(mut p: Parser, mark: i64, statement: i64) -> i64 {
    mut head : i64 = 0 - 1
    mut tail : i64 = 0 - 1
    mut q := mark
    while (q < p.pending.count) {
        queued : ^LocalVar = arena_at(p.pending, q)
        first := queued^.name_off
        last := queued^.name_len
        if (head == (0 - 1)) {
            head = first
        } else {
            set_next(p, tail, first)
        }
        if (first != last) {
            set_next(p, first, last)
        }
        tail = last
        q = q + 1
    }
    p.pending.count = mark
    if (head == (0 - 1)) {
        return statement
    }
    if (statement != (0 - 1)) {
        set_next(p, tail, statement)
    }
    head
}

set_while_preamble :: fn(mut p: Parser, loop: i64, preamble: i64) {
    node : ^Node = arena_at(p.arena, loop)
    node^.c = preamble
}

// The statement a match arm runs, with anything its own parse queued placed
// ahead of it rather than hoisted out of the arm.
parse_arm :: fn(mut p: Parser) -> i64 {
    mark := p.pending.count
    statement := parse_stmt(p)
    flush_pending(p, mark, statement)
}

parse_stmt_list :: fn(mut p: Parser, terminator: i64) -> i64 {
    mut head : i64 = 0 - 1
    mut tail : i64 = 0 - 1
    while (cur(p) != terminator && cur(p) != TOK_EOF) {
        mark := p.pending.count
        parsed := parse_stmt(p)
        statement := flush_pending(p, mark, parsed)
        mut last := statement
        mut following := node_next(p, last)
        while (following != (0 - 1)) {
            last = following
            following = node_next(p, last)
        }
        if (head == (0 - 1)) {
            head = statement
        } else {
            set_next(p, tail, statement)
        }
        tail = last
    }
    head
}

parse_params :: fn(mut p: Parser) -> i64 {
    mut head : i64 = 0 - 1
    mut tail : i64 = 0 - 1
    while (cur(p) != TOK_RPAREN && cur(p) != TOK_EOF) {
        // Capture the parameter mode. `mut` (write) is 1, `move` is 2, and an
        // unmarked read is 0.
        mut mode : i64 = 0
        if (cur(p) == TOK_KW_MUT) {
            mode = 1
            advance(p)
        }
        if (cur(p) == TOK_KW_MOVE) {
            mode = 2
            advance(p)
        }
        // A `$T: Type` parameter declares the type parameter and is erased from
        // the runtime signature, so no PARAM node is created for it.
        if (cur(p) == TOK_DOLLAR) {
            advance(p)
            p.type_param_off = cur_off(p)
            p.type_param_len = cur_len(p)
            p.saw_type_param = 1
            advance(p)
            parse_type_annotation(p)
            if (cur(p) == TOK_COMMA) {
                advance(p)
            }
        } else {
            offset := cur_off(p)
            length := cur_len(p)
            advance(p)
            mut ty := parse_type_annotation(p)
            // A mode borrow of a value is passed by pointer, and the call site
            // takes its address automatically (auto_borrow = 1). `mut` always
            // borrows; an unmarked read borrows a struct or generic instance and
            // passes a scalar by value. An already pointer-typed annotation
            // (a raw pointer) or a `move` stays as written.
            mut auto_borrow : i64 = 0
            if (is_pointer(ty) == false) {
                if (mode == 1) {
                    auto_borrow = 1
                }
                if (mode == 0 && is_struct_ty(ty)) {
                    auto_borrow = 1
                }
                if (mode == 0 && p.last_type_was_generic == 1) {
                    auto_borrow = 1
                }
            }
            if (auto_borrow == 1) {
                ty = POINTER_BASE + ty
            }
            param := arena_push(
                p.arena,
                Node { kind = NODE_PARAM, a = auto_borrow, b = ty, c = length,
                    val = offset, next = 0 - 1 },
            )
            if (head == (0 - 1)) {
                head = param
                tail = param
            } else {
                set_next(p, tail, param)
                tail = param
            }
            if (cur(p) == TOK_COMMA) {
                advance(p)
            }
        }
    }
    advance(p)
    head
}

// A definition is `name :: fn(params) -> ret { body }`. The name, `::`, and `fn`
// are consumed here; an optional `-> type` return annotation is parsed and
// discarded (every function still lowers to an int64_t C function).
parse_function :: fn(mut p: Parser) -> i64 {
    name_offset := cur_off(p)
    name_length := cur_len(p)
    advance(p)
    advance(p)
    advance(p)
    fn_index := intern_global(p, name_offset, name_length)
    mut is_main : i64 = 0
    if (is_main_name(p.src, name_offset, name_length)) {
        is_main = 1
    }
    advance(p)
    mut params := parse_params(p)
    set_params(p, fn_index, params)
    mark_defined(p, fn_index)
    mut ret : i64 = TY_VOID
    if (cur(p) == TOK_ARROW) {
        advance(p)
        ret = parse_type(p)
    }
    // `-> T ! E` answers with a T or fails with an E. The function's real
    // return type is the struct standing for the pair, so everything after this
    // handles an ordinary struct return.
    mut failure : i64 = 0 - 1
    if (cur(p) == TOK_BANG) {
        advance(p)
        failure = parse_type(p)
        ret = synth_result_struct(p, ret, failure)
    }
    p.result_ty = ret
    p.failure_ty = failure
    if (failure == (0 - 1)) {
        p.result_ty = 0 - 1
    }
    p.last_return_type = ret
    set_ret_type(p, fn_index, ret)
    // `-> T uses A` draws an allocation capability. It is an implicit trailing
    // parameter that borrows the source, so after this the function is ordinary
    // and only the call sites need to know to supply it.
    if (cur(p) == TOK_KW_USES) {
        advance(p)
        cap_name_off := cur_off(p)
        cap_name_len := cur_len(p)
        cap_ty := parse_type(p)
        binding := synth_capability_name(p, cap_name_off, cap_name_len)
        capability := arena_push(
            p.arena,
            Node { kind = NODE_PARAM, a = 1, b = POINTER_BASE + cap_ty,
                c = cap_name_len, val = binding, next = 0 - 1 },
        )
        params = append_node(p, params, capability)
        set_params(p, fn_index, params)
        set_uses(p, fn_index, cap_ty, binding, cap_name_len)
    }
    body := parse_block(p)
    if (p.result_ty != (0 - 1)) {
        wrap_trailing_ok(p, body)
    }
    new_func_node(p, body, params, fn_index, is_main)
}

// A struct definition. A plain `name :: struct { ... }` parses its fields now. A
// generic `name :: struct($T: Type) { ... }` records its type parameter and the
// token index of its `{`, then skips the body; each instantiation re-parses the
// fields with the parameter bound.
parse_struct :: fn(mut p: Parser) {
    name_offset := cur_off(p)
    name_length := cur_len(p)
    advance(p)
    advance(p)
    // `Name :: linear struct { ... }` marks a resource that must be consumed
    // exactly once, so the keyword sits between `::` and `struct`.
    mut linear_flag : i64 = 0
    if (cur(p) == TOK_KW_LINEAR) {
        linear_flag = 1
        advance(p)
    }
    advance(p)
    if (cur(p) == TOK_LPAREN) {
        advance(p)
        advance(p)
        tparam_off := cur_off(p)
        tparam_len := cur_len(p)
        advance(p)
        advance(p)
        advance(p)
        advance(p)
        field_token := p.ti
        mut brace_depth : i64 = 0
        mut started : i64 = 0
        while (started == 0 || brace_depth > 0) {
            if (cur(p) == TOK_LBRACE) {
                brace_depth = brace_depth + 1
                started = 1
            }
            if (cur(p) == TOK_RBRACE) {
                brace_depth = brace_depth - 1
            }
            advance(p)
        }
        arena_push(
            p.structs,
            StructDef { name_off = name_offset, name_len = name_length,
                field_head = 0 - 1, is_generic = 1, tparam_off = tparam_off,
                tparam_len = tparam_len, field_token = field_token,
                instance_id = 0 - 1, is_linear = linear_flag },
        )
    } else {
        head := parse_struct_fields(p)
        arena_push(
            p.structs,
            StructDef { name_off = name_offset, name_len = name_length,
                field_head = head, is_generic = 0, tparam_off = 0,
                tparam_len = 0, field_token = 0, instance_id = 0 - 1,
                is_linear = linear_flag },
        )
    }
}

// ---------------------------------------------------------------------------
// Enums. `Kind :: enum { Player, Enemy { damage: i64 } }` is a struct carrying
// a tag beside every variant's fields, each field named for the variant it came
// from. A variant is then a tag value and a set of field names rather than a
// type of its own, which is why construction, field access and matching all
// reduce to what the compiler already does with structs and integers.
//
// The variants sit side by side rather than overlapping, so an enum is as wide
// as all of them together. Overlapping them would be a union, which the C
// backend cannot express as a plain struct, and the space is not what this
// compiler is short of.
// ---------------------------------------------------------------------------

// The variant of `enum_ty` with this name, or -1. A pattern written `.Circle`
// names no enum, so a variant is found by its own name; two enums that each
// carry a variant of the same name are told apart by the scrutinee's type when
// there is one.
find_variant :: fn(mut p: Parser, enum_ty: i64, off: i64, len: i64) -> i64 {
    mut i : i64 = 0
    while (i < p.variants.count) {
        entry : ^Variant = arena_at(p.variants, i)
        if (entry^.name_len == len
            && bytes_equal(p.src, entry^.name_off, off, len)) {
            if (enum_ty == (0 - 1) || entry^.enum_ty == enum_ty) {
                return i
            }
        }
        i = i + 1
    }
    0 - 1
}

// `Name :: enum { A, B { x: i64 } }`. The fields of every variant are laid out
// in one struct behind a tag, each under the name of the variant it came from.
parse_enum :: fn(mut p: Parser) {
    name_offset := cur_off(p)
    name_length := cur_len(p)
    advance(p)
    advance(p)
    advance(p)
    advance(p)
    result_field_names(p)
    tag_field := arena_push(
        p.fields,
        StructField { name_off = p.name_tag, name_len = 3, ty = TY_I64,
            next = 0 - 1 },
    )
    mut tail := tag_field
    // The enum's own index is known before its fields are, since a variant has
    // to record which enum it belongs to.
    enum_index := p.structs.count
    enum_ty := STRUCT_BASE + enum_index
    mut tag : i64 = 0
    while (cur(p) != TOK_RBRACE && cur(p) != TOK_EOF) {
        variant_off := cur_off(p)
        variant_len := cur_len(p)
        advance(p)
        arena_push(
            p.variants,
            Variant { enum_ty = enum_ty, name_off = variant_off,
                name_len = variant_len, tag = tag },
        )
        if (cur(p) == TOK_LBRACE) {
            advance(p)
            while (cur(p) != TOK_RBRACE && cur(p) != TOK_EOF) {
                field_off := cur_off(p)
                field_len := cur_len(p)
                advance(p)
                field_ty := parse_type_annotation(p)
                qualified := synth_join(p, variant_off, variant_len, field_off,
                    field_len)
                field := arena_push(
                    p.fields,
                    StructField { name_off = qualified,
                        name_len = variant_len + field_len + 1, ty = field_ty,
                        next = 0 - 1 },
                )
                set_next_field(p, tail, field)
                tail = field
                if (cur(p) == TOK_COMMA) {
                    advance(p)
                }
            }
            advance(p)
        }
        if (cur(p) == TOK_COMMA) {
            advance(p)
        }
        tag = tag + 1
    }
    advance(p)
    arena_push(
        p.structs,
        StructDef { name_off = name_offset, name_len = name_length,
            field_head = tag_field, is_generic = 0, tparam_off = 0,
            tparam_len = 0, field_token = 0, instance_id = 0 - 1,
            is_linear = 0 },
    )
}

// `Kind::Enemy { damage = 15 }`, or `Kind::Player` with nothing to carry. The
// value is the enum's struct with the variant's tag and the fields it was
// given, under the names the declaration gave them.
parse_variant_value :: fn(mut p: Parser, enum_off: i64, enum_len: i64) -> i64 {
    enum_ty := resolve_lit_type(p, enum_off, enum_len)
    variant_off := cur_off(p)
    variant_len := cur_len(p)
    advance(p)
    index := find_variant(p, enum_ty, variant_off, variant_len)
    if (index < 0) {
        frost_error("frost: '")
        frost_error_src(p.src, enum_off, enum_len)
        frost_error("' has no variant '")
        frost_error_src(p.src, variant_off, variant_len)
        frost_error("'")
        frost_die()
    }
    entry : ^Variant = arena_at(p.variants, index)
    tag_value := new_node(p, NODE_NUM, 0, 0, entry^.tag)
    head := new_field_init(p, tag_value, p.name_tag, 3)
    mut tail := head
    if (cur(p) == TOK_LBRACE && p.no_struct_lit == false) {
        advance(p)
        while (cur(p) != TOK_RBRACE && cur(p) != TOK_EOF) {
            field_off := cur_off(p)
            field_len := cur_len(p)
            advance(p)
            advance(p)
            value := parse_expr(p)
            qualified := synth_join(p, variant_off, variant_len, field_off,
                field_len)
            init := new_field_init(p, value, qualified,
                variant_len + field_len + 1)
            set_next(p, tail, init)
            tail = init
            if (cur(p) == TOK_COMMA) {
                advance(p)
            }
        }
        advance(p)
    }
    new_struct_lit(p, enum_ty, head)
}

// ---------------------------------------------------------------------------
// Failure sets. `-> T ! E` says a function answers with a T or fails with an E,
// and `e?` hands the failure on. Both lower to what the compiler already has: a
// failure set is a struct carrying which of the two it holds beside both, and
// `?` is a binding, a test and a return, written out where the call sits.
//
// A tag beside both payloads rather than a space-saving union: the two are
// never both live, but reading either one is then a plain field of a plain
// struct, which every backend already does.
// ---------------------------------------------------------------------------

// The field names a failure set's struct uses, made once and shared.
result_field_names :: fn(mut p: Parser) {
    if (p.name_tag == 0) {
        p.name_tag = synth_literal(p, "tag")
        p.name_value = synth_literal(p, "value")
        p.name_error = synth_literal(p, "error")
    }
}

// The struct standing for `T ! E`, made fresh per function so its payload types
// are the ones that function declared.
synth_result_struct :: fn(mut p: Parser, ok: i64, bad: i64) -> i64 {
    result_field_names(p)
    tag := arena_push(
        p.fields,
        StructField { name_off = p.name_tag, name_len = 3, ty = TY_I64,
            next = 0 - 1 },
    )
    value := arena_push(
        p.fields,
        StructField { name_off = p.name_value, name_len = 5, ty = ok,
            next = 0 - 1 },
    )
    bad_field := arena_push(
        p.fields,
        StructField { name_off = p.name_error, name_len = 5, ty = bad,
            next = 0 - 1 },
    )
    set_next_field(p, tag, value)
    set_next_field(p, value, bad_field)
    name := synth_numbered(p, "__Result", p.structs.count)
    index := arena_push(
        p.structs,
        StructDef { name_off = name, name_len = 8 + digits_in(p.structs.count),
            field_head = tag, is_generic = 0, tparam_off = 0, tparam_len = 0,
            field_token = 0, instance_id = 0 - 1, is_linear = 0 },
    )
    STRUCT_BASE + index
}

set_next_field :: fn(mut p: Parser, id: i64, following: i64) {
    field : ^StructField = arena_at(p.fields, id)
    field^.next = following
}

// Which side of the failure set a returned value is. Building the error type is
// how a function fails; anything else is the value it answers with. A value
// already of the error type but not built here reads as an ok value, the same
// way the reference compiler reads it.
returns_failure :: fn(mut p: Parser, value: i64) -> bool {
    if (p.failure_ty == (0 - 1)) {
        return false
    }
    node : ^Node = arena_at(p.arena, value)
    node^.kind == NODE_STRUCT_LIT && node^.val == p.failure_ty
}

// Wrap a returned value as whichever side of the failure set it is.
wrap_result :: fn(mut p: Parser, value: i64) -> i64 {
    if (returns_failure(p, value)) {
        return new_result_value(p, p.result_ty, 1, p.name_error, 5, value)
    }
    new_result_value(p, p.result_ty, 0, p.name_value, 5, value)
}

// `Result { tag = <which>, <name> = <payload> }`, the value a fallible function
// answers with. The other payload is left alone, since which one is live is
// exactly what the tag says.
new_result_value :: fn(mut p: Parser, result_ty: i64, which: i64, name_off: i64,
    name_len: i64, payload: i64) -> i64 {
    which_node := arena_push(
        p.arena,
        Node { kind = NODE_NUM, a = 0, b = 0, c = 0, val = which,
            next = 0 - 1 },
    )
    tag_init := new_field_init(p, which_node, p.name_tag, 3)
    payload_init := new_field_init(p, payload, name_off, name_len)
    set_next(p, tag_init, payload_init)
    new_struct_lit(p, result_ty, tag_init)
}

// An extern declaration `name :: extern fn(params) -> ret`. The name is marked
// extern so calls emit it verbatim, and the node carries params and return type
// so a C prototype can be emitted. `val` is the fn index, `b` the params, `c`
// the return type.
parse_extern :: fn(mut p: Parser) -> i64 {
    name_offset := cur_off(p)
    name_length := cur_len(p)
    advance(p)
    advance(p)
    advance(p)
    advance(p)
    fn_index := intern_global(p, name_offset, name_length)
    mark_extern(p, fn_index)
    advance(p)
    params := parse_params(p)
    set_params(p, fn_index, params)
    mark_defined(p, fn_index)
    mut ret : i64 = TY_VOID
    if (cur(p) == TOK_ARROW) {
        advance(p)
        ret = parse_type(p)
    }
    set_ret_type(p, fn_index, ret)
    arena_push(
        p.arena,
        Node { kind = NODE_EXTERN, a = 0, b = params, c = ret, val = fn_index,
            next = 0 - 1 },
    )
}

// A constant `name :: value`, registered for inlining at use sites.
parse_const :: fn(mut p: Parser) {
    name_offset := cur_off(p)
    name_length := cur_len(p)
    advance(p)
    advance(p)
    value := cur_val(p)
    advance(p)
    register_const(p, name_offset, name_length, value)
}

parse_program :: fn(mut p: Parser) -> i64 {
    mut head : i64 = 0 - 1
    mut tail : i64 = 0 - 1
    while (cur(p) == TOK_IDENT) {
        third := peek_kind(p, 2)
        if (third == TOK_KW_ENUM) {
            parse_enum(p)
        } else if (third == TOK_KW_STRUCT || third == TOK_KW_LINEAR) {
            parse_struct(p)
        } else if (third == TOK_KW_EXTERN) {
            item := parse_extern(p)
            if (head == (0 - 1)) {
                head = item
                tail = item
            } else {
                set_next(p, tail, item)
                tail = item
            }
        } else if (third == TOK_INT) {
            parse_const(p)
        } else {
            // A function. Reset the type-parameter state, remember where it
            // starts, and parse it. If it turned out to reference a type
            // parameter it is a generic template, recorded for monomorphization
            // and kept out of the emitted program list.
            p.type_param_off = 0
            p.type_param_len = 0
            p.saw_type_param = 0
            start := p.ti
            item := parse_function(p)
            if (p.saw_type_param == 1) {
                node : ^Node = arena_at(p.arena, item)
                fn_index := node^.val
                tparam_off := p.type_param_off
                tparam_len := p.type_param_len
                record_generic_fn(p, fn_index, tparam_off, tparam_len, start)
            } else {
                if (head == (0 - 1)) {
                    head = item
                    tail = item
                } else {
                    set_next(p, tail, item)
                    tail = item
                }
            }
        }
    }
    head
}

// ---------------------------------------------------------------------------
// Code generation: walk the arena and emit a C translation unit.
// ---------------------------------------------------------------------------

emit_op :: fn(op: i64) {
    match op {
        case 0: frost_emit_str(" + ")
        case 1: frost_emit_str(" - ")
        case 2: frost_emit_str(" * ")
        case 3: frost_emit_str(" / ")
        case 4: frost_emit_str(" % ")
        case 5: frost_emit_str(" < ")
        case 6: frost_emit_str(" > ")
        case 7: frost_emit_str(" <= ")
        case 8: frost_emit_str(" >= ")
        case 9: frost_emit_str(" == ")
        case 10: frost_emit_str(" != ")
        case 11: frost_emit_str(" && ")
        case _: frost_emit_str(" || ")
    }
}

// Re-emit an identifier from the source by its byte range, so a local reference
// becomes the variable's own name in the generated C.
emit_source :: fn(src: ^i8, off: i64, len: i64) {
    mut k : i64 = 0
    while (k < len) {
        frost_emit_char(frost_byte_at(src, off + k))
        k = k + 1
    }
}

// Emit the content of a string literal for C. Frost and C share escape syntax,
// so a backslash escape is passed through whole; the one difference is that Frost
// allows raw newlines and tabs inside a string, which C forbids, so those are
// escaped.
emit_string_content :: fn(src: ^i8, off: i64, len: i64) {
    mut k : i64 = 0
    while (k < len) {
        b := frost_byte_at(src, off + k)
        if (b == CH_BACKSLASH) {
            frost_emit_char(b)
            k = k + 1
            if (k < len) {
                frost_emit_char(frost_byte_at(src, off + k))
            }
        } else if (b == CH_LF) {
            frost_emit_char(CH_BACKSLASH)
            frost_emit_char(CH_LOWER_N)
        } else if (b == CH_TAB) {
            frost_emit_char(CH_BACKSLASH)
            frost_emit_char(CH_LOWER_T)
        } else if (b == CH_CR) {
            k = k
        } else {
            frost_emit_char(b)
        }
        k = k + 1
    }
}

// ---------------------------------------------------------------------------
// Types during code generation. A local's type is recorded when it is bound, so
// a later `:=` or field access can be typed by walking the expression.
// ---------------------------------------------------------------------------

// A name may be bound more than once in one body, once per sibling scope, and
// the binding in scope is the one bound most recently. Locals are recorded in
// declaration order and never popped, so that is the last matching entry, not
// the first: `emit_program` binds `node` to an i64 and later to a `^Node`, and
// answering with the i64 types `node^.next` as a scalar and reads offset zero.
lookup_local :: fn(mut p: Parser, off: i64, len: i64) -> i64 {
    mut i : i64 = 0
    mut found : i64 = TY_I64
    while (i < p.locals.count) {
        entry : ^LocalVar = arena_at(p.locals, i)
        if (entry^.name_len == len
            && bytes_equal(p.src, entry^.name_off, off, len)) {
            found = entry^.ty
        }
        i = i + 1
    }
    found
}

// Whether a name is in scope as a parameter or local. lookup_local answers with
// a type and defaults an unknown name to i64, which cannot distinguish "an i64"
// from "not declared", so a check needs this instead.
// Whether a value of type `from` may stand in for `to`. Scalars and pointers
// convert freely, the way the emitted C does, and a type parameter matches
// anything because it is a placeholder. A struct only matches the same struct,
// which is where real mistakes show up.
types_compatible :: fn(from: i64, to: i64) -> bool {
    if (from == to) {
        return true
    }
    if (from == TY_PARAM || to == TY_PARAM) {
        return true
    }
    if (is_pointer(from) && is_pointer(to)) {
        return true
    }
    if (is_struct_ty(from) || is_struct_ty(to)) {
        return false
    }
    true
}

local_exists :: fn(mut p: Parser, off: i64, len: i64) -> bool {
    mut i : i64 = 0
    while (i < p.locals.count) {
        entry : ^LocalVar = arena_at(p.locals, i)
        if (entry^.name_len == len
            && bytes_equal(p.src, entry^.name_off, off, len)) {
            return true
        }
        i = i + 1
    }
    false
}

// A value handed to a `move` parameter is gone from the caller. Record it so a
// later use is caught rather than silently reading a value that was given away.
mark_moved :: fn(mut p: Parser, value: i64) {
    node : ^Node = arena_at(p.arena, value)
    if (node^.kind == NODE_VAR) {
        off := node^.val
        len := node^.c
        arena_push(p.moved, LocalVar { name_off = off, name_len = len, ty = 0 })
    }
}

is_moved :: fn(mut p: Parser, off: i64, len: i64) -> bool {
    mut i : i64 = 0
    while (i < p.moved.count) {
        entry : ^LocalVar = arena_at(p.moved, i)
        if (entry^.name_len == len
            && bytes_equal(p.src, entry^.name_off, off, len)) {
            return true
        }
        i = i + 1
    }
    false
}

is_linear_type :: fn(mut p: Parser, ty: i64) -> bool {
    if (is_struct_ty(ty) == false) {
        return false
    }
    def : ^StructDef = arena_at(p.structs, struct_index_of(ty))
    if (def^.is_linear == 1) {
        return true
    }
    false
}

// At the end of a body every linear value must have been handed on. One that
// was not is a resource silently dropped.
check_linear_consumed :: fn(mut p: Parser) {
    mut i : i64 = 0
    while (i < p.locals.count) {
        entry : ^LocalVar = arena_at(p.locals, i)
        ty := entry^.ty
        off := entry^.name_off
        len := entry^.name_len
        if (is_linear_type(p, ty)) {
            if (is_moved(p, off, len) == false) {
                frost_error("frost: linear value '")
                frost_error_src(p.src, off, len)
                frost_error("' is never consumed")
                frost_die()
            }
        }
        i = i + 1
    }
}

record_local :: fn(mut p: Parser, off: i64, len: i64, ty: i64) {
    arena_push(p.locals, LocalVar { name_off = off, name_len = len, ty = ty })
}

// The type of a struct field. The base type may be a pointer (a borrow of a
// struct or a `^T`), which is dereferenced one level first, so `a.count` and
// `node^.next` both resolve.
field_type :: fn(mut p: Parser, base_ty: i64, off: i64, len: i64) -> i64 {
    mut struct_ty := base_ty
    if (is_pointer(struct_ty)) {
        struct_ty = pointee(struct_ty)
    }
    if (is_struct_ty(struct_ty) == false) {
        return TY_I64
    }
    def : ^StructDef = arena_at(p.structs, struct_index_of(struct_ty))
    struct_off := def^.name_off
    struct_len := def^.name_len
    mut fid := def^.field_head
    while (fid != (0 - 1)) {
        field : ^StructField = arena_at(p.fields, fid)
        if (field^.name_len == len
            && bytes_equal(p.src, field^.name_off, off, len)) {
            return field^.ty
        }
        fid = field^.next
    }
    // The base is a struct but carries no such field. Emitting the access
    // verbatim would leave it for whatever compiles the output to notice.
    frost_error("frost: struct '")
    frost_error_src(p.src, struct_off, struct_len)
    frost_error("' has no field '")
    frost_error_src(p.src, off, len)
    frost_error("'")
    frost_die()
    TY_I64
}

type_of :: fn(mut p: Parser, id: i64) -> i64 {
    node : ^Node = arena_at(p.arena, id)
    kind := node^.kind
    if (kind == NODE_STRLIT) {
        return POINTER_BASE + TY_I8
    }
    if (kind == NODE_STRUCT_LIT) {
        return node^.val
    }
    if (kind == NODE_VAR) {
        return lookup_local(p, node^.val, node^.c)
    }
    if (kind == NODE_CALL) {
        // A generic function's declared return type still mentions its type
        // parameter, so a call answers with the concrete type recorded for the
        // instantiation it names.
        return call_ret_type(p, node^.a, node^.val)
    }
    if (kind == NODE_FIELD) {
        base := node^.a
        off := node^.val
        len := node^.c
        base_ty := type_of(p, base)
        return field_type(p, base_ty, off, len)
    }
    if (kind == NODE_DEREF) {
        inner := node^.a
        t := type_of(p, inner)
        if (is_pointer(t)) {
            return pointee(t)
        }
        return TY_I64
    }
    if (kind == NODE_INDEX) {
        base := node^.a
        t := type_of(p, base)
        if (is_pointer(t)) {
            return pointee(t)
        }
        return t
    }
    if (kind == NODE_ADDROF) {
        inner := node^.a
        return POINTER_BASE + type_of(p, inner)
    }
    if (kind == NODE_PTR_CAST) {
        return POINTER_BASE + node^.val
    }
    TY_I64
}

// A struct's C name: its source name, plus the module that declared it when
// that is not the root, since two files may each keep a private struct of the
// same name, and plus `_<instance_id>` for a monomorphized instance.
emit_struct_name :: fn(mut p: Parser, struct_index: i64) {
    def : ^StructDef = arena_at(p.structs, struct_index)
    name_off := def^.name_off
    name_len := def^.name_len
    instance_id := def^.instance_id
    emit_source(p.src, name_off, name_len)
    owner := module_at(p.modules, name_off)
    if (owner > 0) {
        frost_emit_str("_m")
        frost_emit_int(owner)
    }
    if (instance_id >= 0) {
        frost_emit_str("_")
        frost_emit_int(instance_id)
    }
}

emit_ctype :: fn(mut p: Parser, ty: i64) {
    if (is_pointer(ty)) {
        emit_ctype(p, pointee(ty))
        frost_emit_str("*")
        return
    }
    if (ty == TY_I64) {
        frost_emit_str("int64_t")
        return
    }
    if (ty == TY_I8) {
        frost_emit_str("char")
        return
    }
    if (ty == TY_U8) {
        frost_emit_str("unsigned char")
        return
    }
    if (ty == TY_BOOL) {
        frost_emit_str("int64_t")
        return
    }
    if (ty == TY_VOID) {
        frost_emit_str("void")
        return
    }
    frost_emit_str("struct ")
    emit_struct_name(p, struct_index_of(ty))
}

emit_struct_lit :: fn(mut p: Parser, struct_ty: i64, inits: i64) {
    frost_emit_str("(struct ")
    emit_struct_name(p, struct_index_of(struct_ty))
    frost_emit_str("){ ")
    mut id := inits
    mut first : bool = true
    while (id != (0 - 1)) {
        if (first == false) {
            frost_emit_str(", ")
        }
        first = false
        node : ^Node = arena_at(p.arena, id)
        off := node^.val
        len := node^.c
        value := node^.a
        next_id := node^.next
        frost_emit_str(".")
        emit_source(p.src, off, len)
        frost_emit_str(" = ")
        emit_expr(p, value)
        id = next_id
    }
    frost_emit_str(" }")
}

emit_expr :: fn(mut p: Parser, id: i64) {
    node : ^Node = arena_at(p.arena, id)
    kind := node^.kind
    if (kind == NODE_NUM) {
        frost_emit_int(node^.val)
        return
    }
    if (kind == NODE_VAR) {
        off := node^.val
        len := node^.c
        if (is_const(p, off, len)) {
            frost_emit_int(const_value(p, off, len))
        } else {
            // Neither a constant nor anything in scope, so the name does not
            // exist. Without this the name would be emitted verbatim and only
            // whatever compiles the output would notice.
            if (local_exists(p, off, len) == false) {
                frost_error("frost: undefined variable '")
                frost_error_src(p.src, off, len)
                frost_error("'")
                frost_die()
            }
            if (is_moved(p, off, len)) {
                frost_error("frost: use of moved value '")
                frost_error_src(p.src, off, len)
                frost_error("'")
                frost_die()
            }
            emit_source(p.src, off, len)
        }
        return
    }
    if (kind == NODE_STRLIT) {
        frost_emit_str("\"")
        emit_string_content(p.src, node^.val, node^.c)
        frost_emit_str("\"")
        return
    }
    if (kind == NODE_TYPEVAL) {
        return
    }
    if (kind == NODE_CALL) {
        fn_index := node^.val
        args := node^.a
        if (generic_fn_of(p, fn_index) >= 0) {
            frost_emit_str("mf_")
            frost_emit_int(fn_index)
            frost_emit_str("_t")
            frost_emit_int(call_type_arg(p, args))
            frost_emit_str("(")
            emit_args(p, args, fn_index)
            frost_emit_str(")")
            return
        }
        sym : ^Sym = arena_at(p.fns, fn_index)
        if (sym^.is_extern == 1) {
            emit_source(p.src, sym^.off, sym^.len)
        } else {
            frost_emit_str("mf_")
            frost_emit_int(fn_index)
        }
        frost_emit_str("(")
        emit_args(p, args, fn_index)
        frost_emit_str(")")
        return
    }
    if (kind == NODE_FIELD) {
        base := node^.a
        off := node^.val
        len := node^.c
        base_ty := type_of(p, base)
        // Resolve the field for its own sake: field_type rejects a name the
        // struct does not carry, which emitting alone would not notice.
        field_type(p, base_ty, off, len)
        if (is_pointer(base_ty)) {
            frost_emit_str("(*(")
            emit_expr(p, base)
            frost_emit_str("))")
        } else {
            emit_expr(p, base)
        }
        frost_emit_str(".")
        emit_source(p.src, off, len)
        return
    }
    if (kind == NODE_DEREF) {
        inner := node^.a
        frost_emit_str("(*(")
        emit_expr(p, inner)
        frost_emit_str("))")
        return
    }
    if (kind == NODE_INDEX) {
        base := node^.a
        index := node^.b
        emit_expr(p, base)
        frost_emit_str("[")
        emit_expr(p, index)
        frost_emit_str("]")
        return
    }
    if (kind == NODE_ADDROF) {
        inner := node^.a
        frost_emit_str("(&(")
        emit_expr(p, inner)
        frost_emit_str("))")
        return
    }
    if (kind == NODE_PTR_CAST) {
        target := node^.val
        expr := node^.a
        frost_emit_str("(")
        emit_ctype(p, target)
        frost_emit_str("*)(")
        emit_expr(p, expr)
        frost_emit_str(")")
        return
    }
    if (kind == NODE_SIZEOF) {
        target := node^.val
        frost_emit_str("sizeof(")
        emit_ctype(p, target)
        frost_emit_str(")")
        return
    }
    if (kind == NODE_STRUCT_LIT) {
        struct_ty := node^.val
        inits := node^.a
        emit_struct_lit(p, struct_ty, inits)
        return
    }
    left := node^.a
    op := node^.val
    right := node^.b
    frost_emit_str("(")
    emit_expr(p, left)
    emit_op(op)
    emit_expr(p, right)
    frost_emit_str(")")
}

// Emit call arguments, skipping type-value arguments (they are erased since a
// type parameter is not a runtime value).
emit_args :: fn(mut p: Parser, head: i64, fn_index: i64) {
    mut id := head
    mut first : bool = true
    sym : ^Sym = arena_at(p.fns, fn_index)
    mut param : i64 = sym^.params
    while (id != (0 - 1)) {
        node : ^Node = arena_at(p.arena, id)
        value := node^.a
        next_id := node^.next
        vnode : ^Node = arena_at(p.arena, value)
        if (vnode^.kind != NODE_TYPEVAL) {
            if (first == false) {
                frost_emit_str(", ")
            }
            first = false
            // Auto-borrow: an argument passed to a mode-borrow (pointer)
            // parameter has its address taken here, unless it is already a
            // pointer (a borrow forwarded onward).
            mut borrow : i64 = 0
            mut moves : i64 = 0
            mut param_next : i64 = 0 - 1
            mut have_param : i64 = 0
            if (param != (0 - 1)) {
                pnode : ^Node = arena_at(p.arena, param)
                param_auto := pnode^.a
                param_ty := pnode^.b
                param_next = pnode^.next
                have_param = 1
                arg_ty := type_of(p, value)
                if (param_auto == 1 && is_pointer(arg_ty) == false) {
                    borrow = 1
                }
                // A struct handed to a parameter that does not borrow is moved.
                if (param_auto == 0 && is_struct_ty(arg_ty)) {
                    moves = 1
                }
                // Check the argument against the parameter. A generic
                // template's parameter types are placeholders bound per
                // instantiation, so they carry nothing to check against. An
                // auto-borrowed argument is a value whose address is taken
                // here, so it answers to the pointee rather than the pointer.
                if (generic_fn_of(p, fn_index) < 0) {
                    mut expected := param_ty
                    if (borrow == 1) {
                        expected = pointee(param_ty)
                    }
                    if (types_compatible(arg_ty, expected) == false) {
                        frost_error("frost: '")
                        frost_error_src(p.src, sym^.off, sym^.len)
                        frost_error("' was passed an argument of the wrong type")
                        frost_die()
                    }
                }
            }
            if (borrow == 1) {
                frost_emit_str("(&(")
                emit_expr(p, value)
                frost_emit_str("))")
            } else {
                emit_expr(p, value)
            }
            if (moves == 1) {
                mark_moved(p, value)
            }
            if (have_param == 1) {
                param = param_next
            }
        }
        id = next_id
    }
    // The capability is the last argument, supplied by the caller's context
    // rather than written at the call.
    if (sym^.uses_ty >= 0) {
        if (first == false) {
            frost_emit_str(", ")
        }
        emit_capability_argument(p, fn_index)
    }
}

// The generic-fns index of a function, or -1 if it is not generic.
generic_fn_of :: fn(mut p: Parser, fn_index: i64) -> i64 {
    mut i : i64 = 0
    while (i < p.generic_fns.count) {
        entry : ^GenericFn = arena_at(p.generic_fns, i)
        if (entry^.fn_index == fn_index) {
            return i
        }
        i = i + 1
    }
    0 - 1
}

// The type argument of a concrete generic-struct instance, or -1 if the type is
// not an instance.
instance_arg_of :: fn(mut p: Parser, ty: i64) -> i64 {
    if (is_struct_ty(ty) == false) {
        return 0 - 1
    }
    si := struct_index_of(ty)
    mut i : i64 = 0
    while (i < p.instances.count) {
        entry : ^Instance = arena_at(p.instances, i)
        if (entry^.struct_index == si) {
            return entry^.arg
        }
        i = i + 1
    }
    0 - 1
}

// Determine the concrete type argument of a generic call: an explicit `$Type`
// argument if present, otherwise inferred from the first argument whose type is
// a generic-struct instance (or a pointer to one).
call_type_arg :: fn(mut p: Parser, head: i64) -> i64 {
    mut id := head
    while (id != (0 - 1)) {
        node : ^Node = arena_at(p.arena, id)
        value := node^.a
        next_id := node^.next
        vnode : ^Node = arena_at(p.arena, value)
        if (vnode^.kind == NODE_TYPEVAL) {
            return vnode^.val
        }
        id = next_id
    }
    id = head
    while (id != (0 - 1)) {
        node : ^Node = arena_at(p.arena, id)
        value := node^.a
        next_id := node^.next
        mut t := type_of(p, value)
        if (is_pointer(t)) {
            t = pointee(t)
        }
        arg := instance_arg_of(p, t)
        if (arg >= 0) {
            return arg
        }
        id = next_id
    }
    TY_I64
}

// Re-parse a generic function with its type parameter bound to `arg`, returning
// the concrete FUNC node. The return type is left in p.last_return_type.
parse_generic_instance :: fn(mut p: Parser, gfn_index: i64, arg: i64) -> i64 {
    gfn : ^GenericFn = arena_at(p.generic_fns, gfn_index)
    tparam_off := gfn^.tparam_off
    tparam_len := gfn^.tparam_len
    token_start := gfn^.token_start
    saved_ti := p.ti
    saved_off := p.type_param_off
    saved_len := p.type_param_len
    saved_bind := p.type_binding
    saved_active := p.binding_active
    p.type_param_off = tparam_off
    p.type_param_len = tparam_len
    p.type_binding = arg
    p.binding_active = 1
    p.ti = token_start
    node := parse_function(p)
    p.ti = saved_ti
    p.type_param_off = saved_off
    p.type_param_len = saved_len
    p.type_binding = saved_bind
    p.binding_active = saved_active
    node
}

emit_stmt :: fn(mut p: Parser, id: i64) {
    node : ^Node = arena_at(p.arena, id)
    kind := node^.kind
    if (kind == NODE_LET) {
        value := node^.a
        annotation := node^.b
        off := node^.val
        len := node^.c
        mut ty := annotation
        if (annotation == (0 - 1)) {
            ty = type_of(p, value)
        }
        emit_ctype(p, ty)
        frost_emit_str(" ")
        emit_source(p.src, off, len)
        frost_emit_str(" = ")
        emit_expr(p, value)
        frost_emit_str(";\n")
        record_local(p, off, len, ty)
        return
    }
    if (kind == NODE_ASSIGN) {
        place := node^.a
        value := node^.b
        place_ty := type_of(p, place)
        value_ty := type_of(p, value)
        if (types_compatible(value_ty, place_ty) == false) {
            frost_error("frost: assigning a value of the wrong type")
            frost_die()
        }
        emit_expr(p, place)
        frost_emit_str(" = ")
        emit_expr(p, value)
        frost_emit_str(";\n")
        return
    }
    if (kind == NODE_EXPRSTMT) {
        emit_expr(p, node^.a)
        frost_emit_str(";\n")
        return
    }
    if (kind == NODE_MATCH) {
        scrutinee := node^.a
        cases := node^.b
        frost_emit_str("switch (")
        emit_expr(p, scrutinee)
        frost_emit_str(") {\n")
        mut cid := cases
        while (cid != (0 - 1)) {
            cnode : ^Node = arena_at(p.arena, cid)
            is_default := cnode^.c
            value := cnode^.val
            body := cnode^.a
            next_case := cnode^.next
            if (is_default == 1) {
                frost_emit_str("default: {\n")
            } else {
                frost_emit_str("case ")
                frost_emit_int(value)
                frost_emit_str(": {\n")
            }
            emit_list(p, body)
            frost_emit_str("} break;\n")
            cid = next_case
        }
        frost_emit_str("}\n")
        return
    }
    if (kind == NODE_PRINT) {
        value := node^.a
        frost_emit_str("printf(\"%lld\\n\", (long long)(")
        emit_expr(p, value)
        frost_emit_str("));\n")
        return
    }
    if (kind == NODE_RETURN) {
        value := node^.a
        if (value == (0 - 1)) {
            frost_emit_str("return 0;\n")
        } else {
            value_ty := type_of(p, value)
            if (is_linear_type(p, value_ty)) {
                mark_moved(p, value)
            }
            if (types_compatible(value_ty, p.current_ret) == false) {
                frost_error("frost: '")
                frost_error_src(p.src, p.current_fn_off, p.current_fn_len)
                frost_error("' returns a value of the wrong type")
                frost_die()
            }
            frost_emit_str("return (")
            emit_expr(p, value)
            frost_emit_str(");\n")
        }
        return
    }
    if (kind == NODE_IF) {
        cond := node^.a
        then_head := node^.b
        else_head := node^.val
        frost_emit_str("if (")
        emit_expr(p, cond)
        frost_emit_str(") {\n")
        emit_list(p, then_head)
        frost_emit_str("}")
        if (else_head != (0 - 1)) {
            frost_emit_str(" else {\n")
            emit_list(p, else_head)
            frost_emit_str("}")
        }
        frost_emit_str("\n")
        return
    }
    if (kind == NODE_WHILE) {
        cond := node^.a
        body := node^.b
        preamble := node^.c
        if (preamble == (0 - 1)) {
            frost_emit_str("while (")
            emit_expr(p, cond)
            frost_emit_str(") {\n")
            emit_list(p, body)
            frost_emit_str("}\n")
            return
        }
        // The condition needs statements run before it can be asked, and it is
        // asked again every time round, so the test moves inside the loop.
        frost_emit_str("while (1) {\n")
        emit_list(p, preamble)
        frost_emit_str("if (!(")
        emit_expr(p, cond)
        frost_emit_str(")) break;\n")
        emit_list(p, body)
        frost_emit_str("}\n")
        return
    }
    if (kind == NODE_WITH) {
        held_kind := p.prov_kind
        held_off := p.prov_off
        held_len := p.prov_len
        set_provider(p, PROVIDER_REGION, node^.val, node^.c)
        frost_emit_str("{\n")
        emit_list(p, node^.a)
        frost_emit_str("}\n")
        set_provider(p, held_kind, held_off, held_len)
        return
    }
}

// The provider in force while a block is emitted: where a call to a `uses`
// function gets its capability. A `uses` function forwards the one it was
// handed; a `with` block supplies the arena it names; anywhere else there is
// none and such a call is an error.
PROVIDER_NONE    :: 0
PROVIDER_FORWARD :: 1
PROVIDER_REGION  :: 2

set_provider :: fn(mut p: Parser, kind: i64, off: i64, len: i64) {
    p.prov_kind = kind
    p.prov_off = off
    p.prov_len = len
}

// A `uses` function forwards the capability it was handed. Anything else starts
// with none, so a `uses` call from outside a region is caught rather than
// silently allocating from somewhere unnamed.
begin_provider :: fn(mut p: Parser, fn_index: i64) {
    sym : ^Sym = arena_at(p.fns, fn_index)
    if (sym^.uses_ty >= 0) {
        set_provider(p, PROVIDER_FORWARD, sym^.cap_off, sym^.cap_len)
        return
    }
    set_provider(p, PROVIDER_NONE, 0, 0)
}

// The capability a call to `fn_index` is handed, emitted as an argument. A
// forwarded one is already a pointer and passes straight through; a region
// supplies the arena by address, the way any borrow is passed.
emit_capability_argument :: fn(mut p: Parser, fn_index: i64) {
    if (p.prov_kind == PROVIDER_NONE) {
        sym : ^Sym = arena_at(p.fns, fn_index)
        frost_error("frost: calling '")
        frost_error_src(p.src, sym^.off, sym^.len)
        frost_error("' needs an allocation capability, so declare `uses` on ")
        frost_error("the caller or wrap the call in a `with` block")
        frost_die()
    }
    if (p.prov_kind == PROVIDER_REGION) {
        frost_emit_str("(&(")
        emit_source(p.src, p.prov_off, p.prov_len)
        frost_emit_str("))")
        return
    }
    emit_source(p.src, p.prov_off, p.prov_len)
}

emit_list :: fn(mut p: Parser, head: i64) {
    mut id := head
    while (id != (0 - 1)) {
        emit_stmt(p, id)
        node : ^Node = arena_at(p.arena, id)
        id = node^.next
    }
}

emit_param_signature :: fn(mut p: Parser, head: i64) {
    if (head == (0 - 1)) {
        frost_emit_str("void")
        return
    }
    mut id := head
    mut first : bool = true
    while (id != (0 - 1)) {
        if (first == false) {
            frost_emit_str(", ")
        }
        first = false
        node : ^Node = arena_at(p.arena, id)
        ty := node^.b
        off := node^.val
        len := node^.c
        next_id := node^.next
        emit_ctype(p, ty)
        frost_emit_str(" ")
        emit_source(p.src, off, len)
        id = next_id
    }
}

record_params :: fn(mut p: Parser, head: i64) {
    mut id := head
    while (id != (0 - 1)) {
        node : ^Node = arena_at(p.arena, id)
        ty := node^.b
        off := node^.val
        len := node^.c
        next_id := node^.next
        record_local(p, off, len, ty)
        id = next_id
    }
}

emit_prototypes :: fn(mut p: Parser, head: i64) {
    mut id := head
    while (id != (0 - 1)) {
        node : ^Node = arena_at(p.arena, id)
        kind := node^.kind
        fn_index := node^.val
        params := node^.b
        is_main := node^.c
        next_id := node^.next
        if (kind == NODE_FUNC && is_main == 0) {
            sym : ^Sym = arena_at(p.fns, fn_index)
            if (sym^.ret_type == TY_VOID) {
                frost_emit_str("int64_t")
            } else {
                emit_ctype(p, sym^.ret_type)
            }
            frost_emit_str(" mf_")
            frost_emit_int(fn_index)
            frost_emit_str("(")
            emit_param_signature(p, params)
            frost_emit_str(");\n")
        }
        id = next_id
    }
}

emit_extern_prototypes :: fn(mut p: Parser, head: i64) {
    mut id := head
    while (id != (0 - 1)) {
        node : ^Node = arena_at(p.arena, id)
        kind := node^.kind
        fn_index := node^.val
        params := node^.b
        ret := node^.c
        next_id := node^.next
        if (kind == NODE_EXTERN) {
            sym : ^Sym = arena_at(p.fns, fn_index)
            name_off := sym^.off
            name_len := sym^.len
            emit_ctype(p, ret)
            frost_emit_str(" ")
            emit_source(p.src, name_off, name_len)
            frost_emit_str("(")
            emit_param_signature(p, params)
            frost_emit_str(");\n")
        }
        id = next_id
    }
}

emit_struct_decls :: fn(mut p: Parser) {
    mut i : i64 = 0
    while (i < p.structs.count) {
        def : ^StructDef = arena_at(p.structs, i)
        is_generic := def^.is_generic
        field_head := def^.field_head
        if (is_generic == 0) {
            frost_emit_str("struct ")
            emit_struct_name(p, i)
            frost_emit_str(" {\n")
            mut fid := field_head
            while (fid != (0 - 1)) {
                field : ^StructField = arena_at(p.fields, fid)
                fty := field^.ty
                off := field^.name_off
                len := field^.name_len
                next_field := field^.next
                emit_ctype(p, fty)
                frost_emit_str(" ")
                emit_source(p.src, off, len)
                frost_emit_str(";\n")
                fid = next_field
            }
            frost_emit_str("};\n")
        }
        i = i + 1
    }
}

// Emit a function body, treating a trailing expression statement as the return
// value (Frost's implicit return) and appending a `return 0;` fallthrough only
// when the body does not already end in a return or a value.
emit_function_body :: fn(mut p: Parser, body: i64) {
    if (body == (0 - 1)) {
        frost_emit_str("return 0;\n")
        return
    }
    mut id := body
    while (id != (0 - 1)) {
        node : ^Node = arena_at(p.arena, id)
        kind := node^.kind
        next_id := node^.next
        if (next_id == (0 - 1)) {
            if (kind == NODE_EXPRSTMT && type_of(p, node^.a) != TY_VOID) {
                frost_emit_str("return (")
                emit_expr(p, node^.a)
                frost_emit_str(");\n")
            } else {
                emit_stmt(p, id)
                if (kind != NODE_RETURN) {
                    frost_emit_str("return 0;\n")
                }
            }
        } else {
            emit_stmt(p, id)
        }
        id = next_id
    }
}

emit_function :: fn(mut p: Parser, id: i64) {
    node : ^Node = arena_at(p.arena, id)
    fn_index := node^.val
    body := node^.a
    params := node^.b
    is_main := node^.c
    sym : ^Sym = arena_at(p.fns, fn_index)
    p.current_ret = sym^.ret_type
    p.current_fn_off = sym^.off
    p.current_fn_len = sym^.len
    p.locals.count = 0
    p.moved.count = 0
    record_params(p, params)
    begin_provider(p, fn_index)
    if (is_main == 1) {
        frost_emit_str("int main(void) {\n")
    } else {
        // The declared return type, so a function may return a pointer or a
        // struct rather than everything answering as an integer. A function
        // that declares nothing still lowers to int64_t, since the body falls
        // through to `return 0`.
        if (sym^.ret_type == TY_VOID) {
            frost_emit_str("int64_t")
        } else {
            emit_ctype(p, sym^.ret_type)
        }
        frost_emit_str(" mf_")
        frost_emit_int(fn_index)
        frost_emit_str("(")
        emit_param_signature(p, params)
        frost_emit_str(") {\n")
    }
    emit_function_body(p, body)
    check_linear_consumed(p)
    frost_emit_str("}\n")
}

// Emit one monomorphization of a generic function: the concrete return type, the
// mangled name mf_<index>_t<arg>, concrete parameters, and the body.
emit_mono_function :: fn(mut p: Parser, id: i64, arg: i64, ret: i64) {
    node : ^Node = arena_at(p.arena, id)
    fn_index := node^.val
    body := node^.a
    params := node^.b
    msym : ^Sym = arena_at(p.fns, fn_index)
    p.current_ret = ret
    p.current_fn_off = msym^.off
    p.current_fn_len = msym^.len
    p.locals.count = 0
    p.moved.count = 0
    record_params(p, params)
    begin_provider(p, fn_index)
    emit_ctype(p, ret)
    frost_emit_str(" mf_")
    frost_emit_int(fn_index)
    frost_emit_str("_t")
    frost_emit_int(arg)
    frost_emit_str("(")
    emit_param_signature(p, params)
    frost_emit_str(") {\n")
    emit_function_body(p, body)
    frost_emit_str("}\n")
}

emit_mono_prototype :: fn(mut p: Parser, id: i64, arg: i64, ret: i64) {
    node : ^Node = arena_at(p.arena, id)
    fn_index := node^.val
    params := node^.b
    emit_ctype(p, ret)
    frost_emit_str(" mf_")
    frost_emit_int(fn_index)
    frost_emit_str("_t")
    frost_emit_int(arg)
    frost_emit_str("(")
    emit_param_signature(p, params)
    frost_emit_str(");\n")
}

// ---------------------------------------------------------------------------
// Native backend. Emits x64 assembly instead of C, so a build no longer pays for
// a C compiler parsing and optimizing generated source. Selected with
// FROST_BACKEND=asm; the C path stays the default until this covers the
// whole language.
//
// Windows x64: integer arguments arrive in rcx, rdx, r8, r9, the caller reserves
// a 32 byte shadow area, and rsp is 16 byte aligned at every call. Expressions
// evaluate into rax with r11 as scratch, and temporaries move through the stack
// 16 bytes at a time so that alignment never drifts.
//
// Scalar subset for now: integers, locals, arithmetic, comparisons, if, while,
// calls and print. Anything else is refused rather than mis-emitted.
// ---------------------------------------------------------------------------

// Emitting assembly a fragment at a time is noisy, so these write one line:
// `asm` for a plain instruction, `asm_i` for one carrying a number.
asm :: fn(text: ^i8) {
    frost_emit_str("    ")
    frost_emit_str(text)
    frost_emit_str("\n")
}

asm_i :: fn(before: ^i8, value: i64, after: ^i8) {
    frost_emit_str("    ")
    frost_emit_str(before)
    frost_emit_int(value)
    frost_emit_str(after)
    frost_emit_str("\n")
}

// A label definition, and a jump or branch to one.
asm_label :: fn(name: ^i8, id: i64) {
    frost_emit_str(name)
    frost_emit_int(id)
    frost_emit_str(":\n")
}

asm_jump :: fn(op: ^i8, name: ^i8, id: i64) {
    frost_emit_str("    ")
    frost_emit_str(op)
    frost_emit_str(" ")
    frost_emit_str(name)
    frost_emit_int(id)
    frost_emit_str("\n")
}

abi_arg_regs :: fn(mut p: Parser) -> i64 {
    if (p.abi_windows == 1) {
        return 4
    }
    6
}

abi_shadow :: fn(mut p: Parser) -> i64 {
    if (p.abi_windows == 1) {
        return 32
    }
    0
}

ASM_FRAME :: 4096


// A struct is as wide as its fields laid end to end. A field may itself be a
// struct, so this cannot just count them: Parser carries eleven arenas, and an
// arena is three words, not one.
// A byte-wide type is one byte. Everything else this compiler has is a word,
// and a struct is its fields laid end to end, each on its own alignment.
is_byte_ty :: fn(ty: i64) -> bool {
    (ty == TY_I8 || ty == TY_U8) && is_pointer(ty) == false
}

align_up :: fn(offset: i64, alignment: i64) -> i64 {
    (offset + alignment - 1) / alignment * alignment
}

align_of :: fn(mut p: Parser, ty: i64) -> i64 {
    if (is_byte_ty(ty)) {
        return 1
    }
    8
}

type_size :: fn(mut p: Parser, ty: i64) -> i64 {
    if (is_byte_ty(ty)) {
        return 1
    }
    if (is_struct_ty(ty) == false) {
        return 8
    }
    def : ^StructDef = arena_at(p.structs, struct_index_of(ty))
    mut fid := def^.field_head
    mut total : i64 = 0
    while (fid != (0 - 1)) {
        field : ^StructField = arena_at(p.fields, fid)
        total = align_up(total, align_of(p, field^.ty))
            + type_size(p, field^.ty)
        fid = field^.next
    }
    align_up(total, 8)
}

field_offset :: fn(mut p: Parser, struct_ty: i64, off: i64, len: i64) -> i64 {
    mut base := struct_ty
    if (is_pointer(base)) {
        base = pointee(base)
    }
    if (is_struct_ty(base) == false) {
        return 0
    }
    def : ^StructDef = arena_at(p.structs, struct_index_of(base))
    mut fid := def^.field_head
    mut running : i64 = 0
    while (fid != (0 - 1)) {
        field : ^StructField = arena_at(p.fields, fid)
        running = align_up(running, align_of(p, field^.ty))
        if (field^.name_len == len
            && bytes_equal(p.src, field^.name_off, off, len)) {
            return running
        }
        running = running + type_size(p, field^.ty)
        fid = field^.next
    }
    0
}

// Carve a temporary out of the bottom of the frame, for a struct literal that
// is used as a value rather than stored straight into a local.
alloc_temp :: fn(mut p: Parser, size: i64) -> i64 {
    slot := p.asm_temp
    p.asm_temp = slot + size
    slot
}

// Copy a struct, a word at a time. Both addresses arrive in registers.
emit_asm_copy :: fn(size: i64) {
    mut moved : i64 = 0
    while (moved < size) {
        asm_i("movq ", moved, "(%r11), %rax")
        asm_i("movq %rax, ", moved, "(%r10)")
        moved = moved + 8
    }
}


cstr_eq :: fn(a: ^i8, b: ^i8) -> bool {
    la := frost_str_len(a)
    lb := frost_str_len(b)
    if (la != lb) {
        return false
    }
    mut i : i64 = 0
    while (i < la) {
        if (frost_byte_at(a, i) != frost_byte_at(b, i)) {
            return false
        }
        i = i + 1
    }
    true
}

new_label :: fn(mut p: Parser) -> i64 {
    id := p.label_id
    p.label_id = id + 1
    id
}

emit_label :: fn(name: ^i8, id: i64) {
    frost_emit_str(name)
    frost_emit_int(id)
}

// Locals are laid end to end from the top of the frame down, so a local sits
// past everything recorded before it. A rebound name takes the slot of its most
// recent binding, matching lookup_local, so the two bindings stay distinct.
local_slot :: fn(mut p: Parser, off: i64, len: i64) -> i64 {
    mut i : i64 = 0
    mut running : i64 = 0
    mut found : i64 = 0 - 8
    while (i < p.locals.count) {
        entry : ^LocalVar = arena_at(p.locals, i)
        running = running + align_up(type_size(p, entry^.ty), 8)
        if (entry^.name_len == len
            && bytes_equal(p.src, entry^.name_off, off, len)) {
            found = 0 - running
        }
        i = i + 1
    }
    found
}

// The address of a place, rather than the value in it.
emit_asm_addr :: fn(mut p: Parser, id: i64) {
    node : ^Node = arena_at(p.arena, id)
    kind := node^.kind
    if (kind == NODE_VAR) {
        asm_i("leaq ", local_slot(p, node^.val, node^.c), "(%rbp), %rax")
        return
    }
    if (kind == NODE_FIELD) {
        base := node^.a
        base_ty := type_of(p, base)
        // A pointer base already holds the address; a struct place needs one.
        if (is_pointer(base_ty)) {
            emit_asm_expr(p, base)
        } else {
            emit_asm_addr(p, base)
        }
        offset := field_offset(p, base_ty, node^.val, node^.c)
        if (offset != 0) {
            asm_i("addq $", offset, ", %rax")
        }
        return
    }
    if (kind == NODE_DEREF) {
        emit_asm_expr(p, node^.a)
        return
    }
    if (kind == NODE_INDEX) {
        base := node^.a
        base_ty := type_of(p, base)
        mut element : i64 = TY_I64
        if (is_pointer(base_ty)) {
            element = pointee(base_ty)
            emit_asm_expr(p, base)
        } else {
            element = base_ty
            emit_asm_addr(p, base)
        }
        emit_asm_push()
        emit_asm_expr(p, node^.b)
        asm_i("imulq $", type_size(p, element), ", %rax")
        asm("movq %rax, %r11")
        emit_asm_pop_rax()
        asm("addq %r11, %rax")
        return
    }
    asm_unsupported("the address of this expression")
}

asm_unsupported :: fn(what: ^i8) {
    frost_error("frost: the native backend does not handle ")
    frost_error(what)
    frost_error(" yet")
    frost_die()
}

emit_asm_push :: fn() {
    asm("subq $16, %rsp")
    asm("movq %rax, (%rsp)")
}

emit_asm_pop_rax :: fn() {
    asm("movq (%rsp), %rax")
    asm("addq $16, %rsp")
}

emit_asm_pop_arg :: fn(mut p: Parser, index: i64) {
    frost_emit_str("    movq (%rsp), ")
    emit_asm_arg_reg(p, index)
    frost_emit_str("\n")
    asm("addq $16, %rsp")
}

// A comparison leaves 0 or 1 in rax.
emit_asm_compare :: fn(setcc: ^i8) {
    asm("cmpq %r11, %rax")
    frost_emit_str("    ")
    frost_emit_str(setcc)
    frost_emit_str(" %al\n")
    asm("movzbq %al, %rax")
}

emit_asm_binop :: fn(op: i64) {
    if (op == 0) {
        asm("addq %r11, %rax")
        return
    }
    if (op == 1) {
        asm("subq %r11, %rax")
        return
    }
    if (op == 2) {
        asm("imulq %r11, %rax")
        return
    }
    if (op == 3) {
        asm("cqto")
        asm("idivq %r11")
        return
    }
    if (op == 4) {
        asm("cqto")
        asm("idivq %r11")
        asm("movq %rdx, %rax")
        return
    }
    if (op == 5) {
        emit_asm_compare("setl")
        return
    }
    if (op == 6) {
        emit_asm_compare("setg")
        return
    }
    if (op == 7) {
        emit_asm_compare("setle")
        return
    }
    if (op == 8) {
        emit_asm_compare("setge")
        return
    }
    if (op == 9) {
        emit_asm_compare("sete")
        return
    }
    if (op == 10) {
        emit_asm_compare("setne")
        return
    }
    // `&&` and `||` over 0/1 values are the bitwise operations.
    if (op == 11) {
        asm("andq %r11, %rax")
        return
    }
    asm("orq %r11, %rax")
}

emit_asm_arg_reg :: fn(mut p: Parser, index: i64) {
    if (p.abi_windows == 1) {
        if (index == 0) { frost_emit_str("%rcx")  return }
        if (index == 1) { frost_emit_str("%rdx")  return }
        if (index == 2) { frost_emit_str("%r8")   return }
        frost_emit_str("%r9")
        return
    }
    if (index == 0) { frost_emit_str("%rdi")  return }
    if (index == 1) { frost_emit_str("%rsi")  return }
    if (index == 2) { frost_emit_str("%rdx")  return }
    if (index == 3) { frost_emit_str("%rcx")  return }
    if (index == 4) { frost_emit_str("%r8")   return }
    frost_emit_str("%r9")
}

emit_asm_expr :: fn(mut p: Parser, id: i64) {
    node : ^Node = arena_at(p.arena, id)
    kind := node^.kind
    if (kind == NODE_NUM) {
        asm_i("movq $", node^.val, ", %rax")
        return
    }
    if (kind == NODE_VAR) {
        off := node^.val
        len := node^.c
        if (is_const(p, off, len)) {
            asm_i("movq $", const_value(p, off, len), ", %rax")
            return
        }
        // A struct is handled by its address, so naming one yields where it
        // lives rather than the first word inside it.
        if (is_struct_ty(lookup_local(p, off, len))) {
            asm_i("leaq ", local_slot(p, off, len), "(%rbp), %rax")
            return
        }
        asm_i("movq ", local_slot(p, off, len), "(%rbp), %rax")
        return
    }
    if (kind == NODE_BIN) {
        emit_asm_expr(p, node^.a)
        emit_asm_push()
        emit_asm_expr(p, node^.b)
        asm("movq %rax, %r11")
        emit_asm_pop_rax()
        emit_asm_binop(node^.val)
        return
    }
    if (kind == NODE_CALL) {
        emit_asm_call(p, node^.a, node^.val)
        return
    }
    if (kind == NODE_STRLIT) {
        asm_i("leaq .Lstr", id, "(%rip), %rax")
        return
    }
    if (kind == NODE_SIZEOF) {
        asm_i("movq $", type_size(p, node^.val), ", %rax")
        return
    }
    // A cast between pointers is a retype, so the value is already right.
    if (kind == NODE_PTR_CAST) {
        emit_asm_expr(p, node^.a)
        return
    }
    if (kind == NODE_ADDROF) {
        emit_asm_addr(p, node^.a)
        return
    }
    // A struct is handled by its address, so reading one of these yields the
    // address and only a scalar is actually loaded.
    if (kind == NODE_FIELD || kind == NODE_DEREF || kind == NODE_INDEX) {
        emit_asm_addr(p, id)
        result := type_of(p, id)
        if (is_byte_ty(result)) {
            asm("movzbq (%rax), %rax")
        } else if (is_struct_ty(result) == false) {
            asm("movq (%rax), %rax")
        }
        return
    }
    if (kind == NODE_STRUCT_LIT) {
        emit_asm_struct_lit(p, id)
        return
    }
    asm_unsupported("this expression")
}

// Build a struct into a temporary and answer with its address.
emit_asm_struct_lit :: fn(mut p: Parser, id: i64) {
    node : ^Node = arena_at(p.arena, id)
    struct_ty := node^.val
    inits := node^.a
    slot := alloc_temp(p, type_size(p, struct_ty))
    mut fid := inits
    while (fid != (0 - 1)) {
        fnode : ^Node = arena_at(p.arena, fid)
        value := fnode^.a
        next_id := fnode^.next
        offset := field_offset(p, struct_ty, fnode^.val, fnode^.c)
        member := field_type(p, struct_ty, fnode^.val, fnode^.c)
        emit_asm_expr(p, value)
        if (is_struct_ty(member)) {
            asm("movq %rax, %r11")
            asm_i("leaq ", slot + offset, "(%rbp), %r10")
            emit_asm_copy(type_size(p, member))
        } else {
            asm_i("movq %rax, ", slot + offset, "(%rbp)")
        }
        fid = next_id
    }
    asm_i("leaq ", slot, "(%rbp), %rax")
}

// Arguments evaluate right to left onto the stack and only then land in the
// registers the ABI names, so an argument that is itself a call cannot clobber
// one already computed.
// The value of the nth argument that survives to runtime, skipping the type
// arguments, which are erased.
record_mono_ret :: fn(mut p: Parser, fn_index: i64, arg: i64, ret: i64) {
    arena_push(p.mono_rets,
        MonoRet { fn_index = fn_index, arg = arg, ret = ret })
}

// Work out every monomorphization's concrete return type. A call needs it to
// type its result and to know whether to hand in a buffer for a struct, and the
// template's own return type still mentions the type parameter. This runs
// before anything is checked or emitted, so both backends see the same answer.
record_mono_rets :: fn(mut p: Parser) {
    mut gi : i64 = 0
    while (gi < p.generic_fns.count) {
        mut ii : i64 = 0
        while (ii < p.instances.count) {
            inst : ^Instance = arena_at(p.instances, ii)
            arg := inst^.arg
            node := parse_generic_instance(p, gi, arg)
            fnode : ^Node = arena_at(p.arena, node)
            record_mono_ret(p, fnode^.val, arg, p.last_return_type)
            ii = ii + 1
        }
        gi = gi + 1
    }
}

mono_ret_type :: fn(mut p: Parser, fn_index: i64, arg: i64) -> i64 {
    mut i : i64 = 0
    while (i < p.mono_rets.count) {
        entry : ^MonoRet = arena_at(p.mono_rets, i)
        if (entry^.fn_index == fn_index && entry^.arg == arg) {
            return entry^.ret
        }
        i = i + 1
    }
    TY_I64
}

// What a call answers with, which decides whether it needs a result buffer.
call_ret_type :: fn(mut p: Parser, args: i64, fn_index: i64) -> i64 {
    if (generic_fn_of(p, fn_index) >= 0) {
        return mono_ret_type(p, fn_index, call_type_arg(p, args))
    }
    sym : ^Sym = arena_at(p.fns, fn_index)
    sym^.ret_type
}

nth_value_arg :: fn(mut p: Parser, args: i64, n: i64) -> i64 {
    mut id := args
    mut seen : i64 = 0
    while (id != (0 - 1)) {
        node : ^Node = arena_at(p.arena, id)
        value := node^.a
        next_id := node^.next
        vnode : ^Node = arena_at(p.arena, value)
        if (vnode^.kind != NODE_TYPEVAL) {
            if (seen == n) {
                return value
            }
            seen = seen + 1
        }
        id = next_id
    }
    0 - 1
}

count_value_args :: fn(mut p: Parser, args: i64) -> i64 {
    mut id := args
    mut count : i64 = 0
    while (id != (0 - 1)) {
        node : ^Node = arena_at(p.arena, id)
        value := node^.a
        next_id := node^.next
        vnode : ^Node = arena_at(p.arena, value)
        if (vnode^.kind != NODE_TYPEVAL) {
            count = count + 1
        }
        id = next_id
    }
    count
}

// Arguments evaluate right to left onto the stack and only then move into
// place, so an argument that is itself a call cannot clobber one already
// computed. The first four travel in registers; the rest sit above the shadow
// area the callee is entitled to, and the whole call frame stays 16 byte
// aligned.
// The capability a call is handed, left in %rax ready to be pushed. A forwarded
// one is already a pointer; a region supplies the arena by address.
emit_asm_capability :: fn(mut p: Parser, fn_index: i64) {
    if (p.prov_kind == PROVIDER_NONE) {
        sym : ^Sym = arena_at(p.fns, fn_index)
        frost_error("frost: calling '")
        frost_error_src(p.src, sym^.off, sym^.len)
        frost_error("' needs an allocation capability, so declare `uses` on ")
        frost_error("the caller or wrap the call in a `with` block")
        frost_die()
    }
    slot := local_slot(p, p.prov_off, p.prov_len)
    if (p.prov_kind == PROVIDER_REGION) {
        asm_i("leaq ", slot, "(%rbp), %rax")
        return
    }
    asm_i("movq ", slot, "(%rbp), %rax")
}

emit_asm_call :: fn(mut p: Parser, args: i64, fn_index: i64) {
    callee : ^Sym = arena_at(p.fns, fn_index)
    mut capability : i64 = 0
    if (callee^.uses_ty >= 0) {
        capability = 1
    }
    value_count := count_value_args(p, args)
    count := value_count + capability
    ret := call_ret_type(p, args, fn_index)
    mut sret : i64 = 0
    mut result_slot : i64 = 0
    if (is_struct_ty(ret)) {
        sret = 1
        result_slot = alloc_temp(p, type_size(p, ret))
    }

    // Arguments are pushed last to first, so the capability, being last, goes
    // first and lands in the highest slot.
    if (capability == 1) {
        emit_asm_capability(p, fn_index)
        emit_asm_push()
    }
    mut i : i64 = value_count - 1
    while (i >= 0) {
        emit_asm_expr(p, nth_value_arg(p, args, i))
        emit_asm_push()
        i = i - 1
    }

    total := count + sret
    regs := abi_arg_regs(p)
    shadow := abi_shadow(p)
    mut spill : i64 = 0
    if (total > regs) {
        spill = ((total - regs) * 8 + 15) / 16 * 16
    }
    frame := shadow + spill
    asm_i("subq $", frame, ", %rsp")

    // The hidden result pointer, when there is one, occupies the first slot and
    // pushes every real argument along by one.
    if (sret == 1) {
        frost_emit_str("    leaq ")
        frost_emit_int(result_slot)
        frost_emit_str("(%rbp), ")
        emit_asm_arg_reg(p, 0)
        frost_emit_str("\n")
    }
    mut r : i64 = 0
    while (r < count) {
        dest := r + sret
        frost_emit_str("    movq ")
        frost_emit_int(frame + 16 * r)
        frost_emit_str("(%rsp), ")
        if (dest < regs) {
            emit_asm_arg_reg(p, dest)
            frost_emit_str("\n")
        } else {
            frost_emit_str("%r10\n")
            asm_i("movq %r10, ", shadow + 8 * (dest - regs), "(%rsp)")
        }
        r = r + 1
    }

    sym : ^Sym = arena_at(p.fns, fn_index)
    if (p.abi_windows == 0 && sym^.is_extern == 1) {
        asm("movb $0, %al")
    }
    frost_emit_str("    call ")
    if (generic_fn_of(p, fn_index) >= 0) {
        frost_emit_str("mf_")
        frost_emit_int(fn_index)
        frost_emit_str("_t")
        frost_emit_int(call_type_arg(p, args))
    } else {
        if (sym^.is_extern == 1) {
            emit_source(p.src, sym^.off, sym^.len)
        } else {
            frost_emit_str("mf_")
            frost_emit_int(fn_index)
        }
    }
    frost_emit_str("\n")
    asm_i("addq $", frame + 16 * count, ", %rsp")
}

emit_asm_stmt :: fn(mut p: Parser, id: i64) {
    node : ^Node = arena_at(p.arena, id)
    kind := node^.kind
    if (kind == NODE_LET) {
        value := node^.a
        annotation := node^.b
        off := node^.val
        len := node^.c
        mut ty := annotation
        if (annotation == (0 - 1)) {
            ty = type_of(p, value)
        }
        emit_asm_expr(p, value)
        record_local(p, off, len, ty)
        slot := local_slot(p, off, len)
        if (is_struct_ty(ty)) {
            asm("movq %rax, %r11")
            asm_i("leaq ", slot, "(%rbp), %r10")
            emit_asm_copy(type_size(p, ty))
            return
        }
        asm_i("movq %rax, ", slot, "(%rbp)")
        return
    }
    if (kind == NODE_ASSIGN) {
        place := node^.a
        value := node^.b
        place_ty := type_of(p, place)
        emit_asm_addr(p, place)
        emit_asm_push()
        emit_asm_expr(p, value)
        if (is_struct_ty(place_ty)) {
            asm("movq %rax, %r11")
            emit_asm_pop_rax()
            asm("movq %rax, %r10")
            emit_asm_copy(type_size(p, place_ty))
            return
        }
        asm("movq %rax, %r11")
        emit_asm_pop_rax()
        if (is_byte_ty(place_ty)) {
            asm("movb %r11b, (%rax)")
        } else {
            asm("movq %r11, (%rax)")
        }
        return
    }
    if (kind == NODE_RETURN) {
        emit_asm_return(p, node^.a)
        return
    }
    if (kind == NODE_PRINT) {
        shadow := abi_shadow(p)
        emit_asm_expr(p, node^.a)
        // printf takes the format then the value, in whichever registers this
        // convention names, and System V wants the vector register count in al.
        frost_emit_str("    movq %rax, ")
        emit_asm_arg_reg(p, 1)
        frost_emit_str("\n")
        frost_emit_str("    leaq .Lfmt(%rip), ")
        emit_asm_arg_reg(p, 0)
        frost_emit_str("\n")
        if (p.abi_windows == 0) {
            asm("movb $0, %al")
        }
        asm_i("subq $", shadow, ", %rsp")
        asm("call printf")
        asm_i("addq $", shadow, ", %rsp")
        return
    }
    if (kind == NODE_IF) {
        else_id := new_label(p)
        end_id := new_label(p)
        emit_asm_expr(p, node^.a)
        asm("cmpq $0, %rax")
        frost_emit_str("    je ")
        emit_label(".Lelse", else_id)
        frost_emit_str("\n")
        emit_asm_block(p, node^.b)
        frost_emit_str("    jmp ")
        emit_label(".Lend", end_id)
        frost_emit_str("\n")
        emit_label(".Lelse", else_id)
        frost_emit_str(":\n")
        else_head := node^.val
        if (else_head != (0 - 1)) {
            emit_asm_block(p, else_head)
        }
        emit_label(".Lend", end_id)
        frost_emit_str(":\n")
        return
    }
    if (kind == NODE_WHILE) {
        top_id := new_label(p)
        end_id := new_label(p)
        emit_label(".Ltop", top_id)
        frost_emit_str(":\n")
        emit_asm_block(p, node^.c)
        emit_asm_expr(p, node^.a)
        asm("cmpq $0, %rax")
        frost_emit_str("    je ")
        emit_label(".Lend", end_id)
        frost_emit_str("\n")
        emit_asm_block(p, node^.b)
        frost_emit_str("    jmp ")
        emit_label(".Ltop", top_id)
        frost_emit_str("\n")
        emit_label(".Lend", end_id)
        frost_emit_str(":\n")
        return
    }
    if (kind == NODE_EXPRSTMT) {
        emit_asm_expr(p, node^.a)
        return
    }
    if (kind == NODE_WITH) {
        held_kind := p.prov_kind
        held_off := p.prov_off
        held_len := p.prov_len
        set_provider(p, PROVIDER_REGION, node^.val, node^.c)
        emit_asm_block(p, node^.a)
        set_provider(p, held_kind, held_off, held_len)
        return
    }
    // A match is a chain of comparisons against the scrutinee, which is kept in
    // a temporary because each arm's body may clobber the registers.
    if (kind == NODE_MATCH) {
        scrutinee := node^.a
        cases := node^.b
        end_id := new_label(p)
        slot := alloc_temp(p, 8)
        emit_asm_expr(p, scrutinee)
        asm_i("movq %rax, ", slot, "(%rbp)")
        mut cid := cases
        while (cid != (0 - 1)) {
            cnode : ^Node = arena_at(p.arena, cid)
            is_default := cnode^.c
            value := cnode^.val
            body := cnode^.a
            next_case := cnode^.next
            if (is_default == 1) {
                emit_asm_block(p, body)
                frost_emit_str("    jmp ")
                emit_label(".Lend", end_id)
                frost_emit_str("\n")
            } else {
                skip_id := new_label(p)
                asm_i("movq ", slot, "(%rbp), %rax")
                asm_i("cmpq $", value, ", %rax")
                frost_emit_str("    jne ")
                emit_label(".Lcase", skip_id)
                frost_emit_str("\n")
                emit_asm_block(p, body)
                frost_emit_str("    jmp ")
                emit_label(".Lend", end_id)
                frost_emit_str("\n")
                emit_label(".Lcase", skip_id)
                frost_emit_str(":\n")
            }
            cid = next_case
        }
        emit_label(".Lend", end_id)
        frost_emit_str(":\n")
        return
    }
    asm_unsupported("this statement")
}

// Leave a function. A struct result is copied into the buffer the caller
// supplied, because the frame it was built in is about to go away.
emit_asm_return :: fn(mut p: Parser, value: i64) {
    if (value == (0 - 1)) {
        asm("movq $0, %rax")
        asm("leave")
        asm("ret")
        return
    }
    emit_asm_expr(p, value)
    if (is_struct_ty(p.asm_ret)) {
        asm("movq %rax, %r11")
        asm_i("movq ", p.sret_slot, "(%rbp), %r10")
        emit_asm_copy(type_size(p, p.asm_ret))
        asm_i("movq ", p.sret_slot, "(%rbp), %rax")
    }
    asm("leave")
    asm("ret")
}

// A body's last statement, when it is an expression, is its result.
emit_asm_function_body :: fn(mut p: Parser, body: i64) {
    if (body == (0 - 1)) {
        asm("movq $0, %rax")
        asm("leave")
        asm("ret")
        return
    }
    mut id := body
    while (id != (0 - 1)) {
        node : ^Node = arena_at(p.arena, id)
        kind := node^.kind
        next_id := node^.next
        if (next_id == (0 - 1)) {
            if (kind == NODE_EXPRSTMT && type_of(p, node^.a) != TY_VOID) {
                emit_asm_return(p, node^.a)
            } else {
                emit_asm_stmt(p, id)
                if (kind != NODE_RETURN) {
                    asm("movq $0, %rax")
                    asm("leave")
                    asm("ret")
                }
            }
        } else {
            emit_asm_stmt(p, id)
        }
        id = next_id
    }
}

emit_asm_block :: fn(mut p: Parser, head: i64) {
    mut id := head
    while (id != (0 - 1)) {
        node : ^Node = arena_at(p.arena, id)
        next_id := node^.next
        emit_asm_stmt(p, id)
        id = next_id
    }
}

// The shared shape of every emitted function: frame, incoming arguments, body.
// `ret` is the concrete return type, which decides whether the caller handed in
// a buffer for a struct result.
emit_asm_frame :: fn(mut p: Parser, body: i64, params: i64, ret: i64) {
    p.locals.count = 0
    p.moved.count = 0
    p.asm_temp = 32 - ASM_FRAME
    p.asm_ret = ret
    asm("pushq %rbp")
    asm("movq %rsp, %rbp")
    // Windows grows the stack through a guard page, so a frame wider than one
    // page has to touch each page on the way down or the guard is stepped over
    // and the access faults.
    mut left : i64 = ASM_FRAME
    while (left > 4096) {
        asm("subq $4096, %rsp")
        asm("movq $0, (%rsp)")
        left = left - 4096
    }
    asm_i("subq $", left, ", %rsp")

    // A struct result arrives as a hidden pointer ahead of the real arguments.
    regs := abi_arg_regs(p)
    shadow := abi_shadow(p)
    mut shift : i64 = 0
    if (is_struct_ty(ret)) {
        shift = 1
        p.sret_slot = alloc_temp(p, 8)
        frost_emit_str("    movq ")
        emit_asm_arg_reg(p, 0)
        frost_emit_str(", ")
        frost_emit_int(p.sret_slot)
        frost_emit_str("(%rbp)\n")
    }

    // The first four arguments arrive in registers; the rest were left on the
    // stack by the caller, above the saved frame pointer, the return address
    // and the shadow area.
    mut pid := params
    mut index : i64 = 0
    while (pid != (0 - 1)) {
        pnode : ^Node = arena_at(p.arena, pid)
        off := pnode^.val
        len := pnode^.c
        next_id := pnode^.next
        record_local(p, off, len, pnode^.b)
        slot := local_slot(p, off, len)
        place := index + shift
        ptype := pnode^.b
        // A struct argument travels as an address, so a parameter that owns one
        // copies it into its own slot rather than keeping the caller's pointer.
        if (is_struct_ty(ptype)) {
            if (place < regs) {
                frost_emit_str("    movq ")
                emit_asm_arg_reg(p, place)
                frost_emit_str(", %r11\n")
            } else {
                asm_i("movq ", 16 + shadow + 8 * (place - regs), "(%rbp), %r11")
            }
            asm_i("leaq ", slot, "(%rbp), %r10")
            emit_asm_copy(type_size(p, ptype))
        } else {
            if (place < regs) {
                frost_emit_str("    movq ")
                emit_asm_arg_reg(p, place)
                frost_emit_str(", ")
                frost_emit_int(slot)
                frost_emit_str("(%rbp)\n")
            } else {
                asm_i("movq ", 16 + shadow + 8 * (place - regs), "(%rbp), %r10")
                asm_i("movq %r10, ", slot, "(%rbp)")
            }
        }
        index = index + 1
        pid = next_id
    }

    emit_asm_function_body(p, body)
    asm("movq $0, %rax")
    asm("leave")
    asm("ret")
}

emit_asm_function :: fn(mut p: Parser, id: i64) {
    node : ^Node = arena_at(p.arena, id)
    fn_index := node^.val
    body := node^.a
    params := node^.b
    is_main := node^.c
    sym : ^Sym = arena_at(p.fns, fn_index)
    ret := sym^.ret_type
    begin_provider(p, fn_index)
    frost_emit_str("    .globl ")
    if (is_main == 1) {
        frost_emit_str("main\n")
        frost_emit_str("main:\n")
    } else {
        frost_emit_str("mf_")
        frost_emit_int(fn_index)
        frost_emit_str("\n")
        frost_emit_str("mf_")
        frost_emit_int(fn_index)
        frost_emit_str(":\n")
    }
    emit_asm_frame(p, body, params, ret)
}

// One monomorphization, under the name its call sites use.
emit_asm_mono_function :: fn(mut p: Parser, id: i64, arg: i64, ret: i64) {
    node : ^Node = arena_at(p.arena, id)
    fn_index := node^.val
    body := node^.a
    params := node^.b
    begin_provider(p, fn_index)
    frost_emit_str("    .globl mf_")
    frost_emit_int(fn_index)
    frost_emit_str("_t")
    frost_emit_int(arg)
    frost_emit_str("\n")
    frost_emit_str("mf_")
    frost_emit_int(fn_index)
    frost_emit_str("_t")
    frost_emit_int(arg)
    frost_emit_str(":\n")
    emit_asm_frame(p, body, params, ret)
}

emit_asm_program :: fn(mut p: Parser, head: i64) {
    asm(".text")
    mut id := head
    while (id != (0 - 1)) {
        node : ^Node = arena_at(p.arena, id)
        kind := node^.kind
        next_id := node^.next
        if (kind == NODE_FUNC) {
            emit_asm_function(p, id)
        }
        id = next_id
    }

    mut gi : i64 = 0
    while (gi < p.generic_fns.count) {
        mut ii : i64 = 0
        while (ii < p.instances.count) {
            inst : ^Instance = arena_at(p.instances, ii)
            arg := inst^.arg
            node := parse_generic_instance(p, gi, arg)
            ret := p.last_return_type
            emit_asm_mono_function(p, node, arg, ret)
            ii = ii + 1
        }
        gi = gi + 1
    }

    asm(".data")
    frost_emit_str(".Lfmt:\n")
    frost_emit_str("    .asciz \"%lld\\n\"\n")
    emit_asm_strings(p)
}

// Every string literal in the program, labelled by the node that holds it.
emit_asm_strings :: fn(mut p: Parser) {
    mut i : i64 = 0
    while (i < p.arena.count) {
        node : ^Node = arena_at(p.arena, i)
        kind := node^.kind
        off := node^.val
        len := node^.c
        if (kind == NODE_STRLIT) {
            frost_emit_str(".Lstr")
            frost_emit_int(i)
            frost_emit_str(":\n")
            frost_emit_str("    .asciz \"")
            emit_string_content(p.src, off, len)
            frost_emit_str("\"\n")
        }
        i = i + 1
    }
}

emit_program :: fn(mut p: Parser, head: i64) {
    emit_struct_decls(p)
    emit_extern_prototypes(p, head)

    // Prototypes for each monomorphization, so they may be called before defined.
    mut gi : i64 = 0
    while (gi < p.generic_fns.count) {
        mut ii : i64 = 0
        while (ii < p.instances.count) {
            inst : ^Instance = arena_at(p.instances, ii)
            arg := inst^.arg
            node := parse_generic_instance(p, gi, arg)
            ret := p.last_return_type
            emit_mono_prototype(p, node, arg, ret)
            ii = ii + 1
        }
        gi = gi + 1
    }

    emit_prototypes(p, head)

    // Monomorphized function definitions.
    gi = 0
    while (gi < p.generic_fns.count) {
        mut ii : i64 = 0
        while (ii < p.instances.count) {
            inst : ^Instance = arena_at(p.instances, ii)
            arg := inst^.arg
            node := parse_generic_instance(p, gi, arg)
            ret := p.last_return_type
            emit_mono_function(p, node, arg, ret)
            ii = ii + 1
        }
        gi = gi + 1
    }

    mut id := head
    while (id != (0 - 1)) {
        node : ^Node = arena_at(p.arena, id)
        kind := node^.kind
        next_id := node^.next
        if (kind == NODE_FUNC) {
            emit_function(p, id)
        }
        id = next_id
    }
}

// ---------------------------------------------------------------------------
// Checks. The compiler answers for its own errors rather than deferring them to
// whatever compiles its output. Every node ever parsed lives in one arena, so a
// linear scan over it reaches every call without walking the tree.
// ---------------------------------------------------------------------------

count_params :: fn(mut p: Parser, head: i64) -> i64 {
    mut count : i64 = 0
    mut id := head
    while (id != (0 - 1)) {
        node : ^Node = arena_at(p.arena, id)
        count = count + 1
        id = node^.next
    }
    count
}

// A type argument is erased before runtime, so it is not counted against the
// parameter list, which never has a node for a type parameter either.
count_args :: fn(mut p: Parser, head: i64) -> i64 {
    mut count : i64 = 0
    mut id := head
    while (id != (0 - 1)) {
        node : ^Node = arena_at(p.arena, id)
        value := node^.a
        next_id := node^.next
        vnode : ^Node = arena_at(p.arena, value)
        kind := vnode^.kind
        if (kind != NODE_TYPEVAL) {
            count = count + 1
        }
        id = next_id
    }
    count
}

// ---------------------------------------------------------------------------
// Regions. A `with arena { ... }` block is a region: a raw pointer derived from
// the arena inside it dies with the block, so it may not be assigned to
// anything declared outside the block or returned. There are no lifetimes and
// no region types on pointers, only a walk over the block tracking which names
// hold arena pointers. That is enough here because the language has no global
// arenas and no closures, so a pointer can only reach an arena a function was
// handed directly.
// ---------------------------------------------------------------------------

name_listed :: fn(mut table: Arena<LocalVar>, src: ^i8, off: i64, len: i64)
    -> bool {
    mut i : i64 = 0
    while (i < table.count) {
        entry : ^LocalVar = arena_at(table, i)
        if (entry^.name_len == len
            && bytes_equal(src, entry^.name_off, off, len)) {
            return true
        }
        i = i + 1
    }
    false
}

list_name :: fn(mut table: Arena<LocalVar>, off: i64, len: i64) {
    arena_push(table, LocalVar { name_off = off, name_len = len, ty = 0 })
}

// The name a place is rooted at, walking down through fields, indexes and
// dereferences, or -1 if the place is not rooted at a name.
root_name :: fn(mut p: Parser, id: i64) -> i64 {
    mut current := id
    while (current != (0 - 1)) {
        node : ^Node = arena_at(p.arena, current)
        kind := node^.kind
        if (kind == NODE_VAR) {
            return current
        }
        if (kind == NODE_FIELD || kind == NODE_INDEX || kind == NODE_DEREF
            || kind == NODE_ADDROF || kind == NODE_PTR_CAST) {
            current = node^.a
        } else {
            return 0 - 1
        }
    }
    0 - 1
}

// Whether an expression names the region's arena or anything already known to
// point into it.
mentions_region :: fn(mut p: Parser, id: i64) -> bool {
    if (id == (0 - 1)) {
        return false
    }
    node : ^Node = arena_at(p.arena, id)
    kind := node^.kind
    if (kind == NODE_VAR) {
        off := node^.val
        len := node^.c
        if (len == p.region_len
            && bytes_equal(p.src, p.region_off, off, len)) {
            return true
        }
        return name_listed(p.tainted, p.src, off, len)
    }
    if (kind == NODE_NUM || kind == NODE_STRLIT || kind == NODE_TYPEVAL) {
        return false
    }
    if (kind == NODE_CALL) {
        return mentions_region_args(p, node^.a)
    }
    mentions_region(p, node^.a) || mentions_region(p, node^.b)
}

mentions_region_args :: fn(mut p: Parser, head: i64) -> bool {
    mut id := head
    while (id != (0 - 1)) {
        node : ^Node = arena_at(p.arena, id)
        next_id := node^.next
        if (mentions_region(p, node^.a)) {
            return true
        }
        id = next_id
    }
    false
}

// Whether a value points into the region. A pointer taken of something that
// mentions the arena is one; so is the result of a call that returns a pointer
// and either draws from an allocation source or was handed the arena.
region_pointer :: fn(mut p: Parser, id: i64) -> bool {
    if (id == (0 - 1)) {
        return false
    }
    node : ^Node = arena_at(p.arena, id)
    kind := node^.kind
    if (kind == NODE_ADDROF) {
        return mentions_region(p, node^.a)
    }
    if (kind == NODE_VAR) {
        return name_listed(p.tainted, p.src, node^.val, node^.c)
    }
    // A cast still points where it pointed. A dereference does not: it reads
    // the value there, and reading out of the region is what the region is for.
    if (kind == NODE_PTR_CAST) {
        return region_pointer(p, node^.a)
    }
    if (kind == NODE_CALL) {
        sym : ^Sym = arena_at(p.fns, node^.val)
        if (is_pointer(sym^.ret_type) == false) {
            return false
        }
        if (sym^.uses_ty >= 0) {
            return true
        }
        return mentions_region_args(p, node^.a)
    }
    false
}

region_escape :: fn(mut p: Parser, how: ^i8) {
    frost_error("frost: a pointer into arena '")
    frost_error_src(p.src, p.region_off, p.region_len)
    frost_error("' escapes its region by ")
    frost_error(how)
    frost_error("; it may not outlive the arena")
    frost_die()
}

check_region_block :: fn(mut p: Parser, head: i64) {
    mut id := head
    while (id != (0 - 1)) {
        node : ^Node = arena_at(p.arena, id)
        kind := node^.kind
        next_id := node^.next
        if (kind == NODE_LET) {
            // A binding declared inside the region dies with it, so it may hold
            // a region pointer.
            if (region_pointer(p, node^.a)) {
                list_name(p.tainted, node^.val, node^.c)
            }
            list_name(p.inner, node^.val, node^.c)
        }
        if (kind == NODE_ASSIGN) {
            if (region_pointer(p, node^.b)) {
                place := root_name(p, node^.a)
                mut outside : bool = true
                if (place != (0 - 1)) {
                    pnode : ^Node = arena_at(p.arena, place)
                    outside = name_listed(p.inner, p.src, pnode^.val,
                        pnode^.c) == false
                }
                if (outside) {
                    if (p.region_returns == 1) {
                        region_escape(p, "being stored into a parameter")
                    }
                    region_escape(p, "being stored outside it")
                }
            }
        }
        // Handing a pointer back is an escape from a `with` block, whose arena
        // dies at the closing brace. It is not one from a `uses` function: the
        // arena belongs to the caller, so the pointer is handed to the caller's
        // region and checked there.
        if (kind == NODE_RETURN && p.region_returns == 0) {
            if (region_pointer(p, node^.a)) {
                region_escape(p, "being returned")
            }
        }
        if (kind == NODE_EXPRSTMT && p.region_returns == 0) {
            if (next_id == (0 - 1) && region_pointer(p, node^.a)) {
                region_escape(p, "being the block's value")
            }
        }
        if (kind == NODE_IF) {
            check_region_block(p, node^.b)
            check_region_block(p, node^.val)
        }
        if (kind == NODE_WHILE) {
            check_region_block(p, node^.b)
        }
        if (kind == NODE_WITH) {
            check_region_block(p, node^.a)
        }
        id = next_id
    }
}

// Every `with` block in the program is a region, and so is the body of every
// `uses` function, whose arena belongs to whoever supplied it. Each is checked
// on its own, since a region's arena is the only thing its pointers can point
// into. This is what makes the check interprocedural without lifetimes: a
// pointer can only reach an arena a function was handed directly, so following
// the flow inside each body is enough.
check_regions :: fn(mut p: Parser) {
    mut i : i64 = 0
    while (i < p.arena.count) {
        node : ^Node = arena_at(p.arena, i)
        kind := node^.kind
        if (kind == NODE_WITH) {
            body := node^.a
            p.region_off = node^.val
            p.region_len = node^.c
            p.tainted.count = 0
            p.inner.count = 0
            p.region_returns = 0
            check_region_block(p, body)
        }
        if (kind == NODE_FUNC) {
            sym : ^Sym = arena_at(p.fns, node^.val)
            if (sym^.uses_ty >= 0) {
                body := node^.a
                p.region_off = sym^.cap_off
                p.region_len = sym^.cap_len
                p.tainted.count = 0
                p.inner.count = 0
                p.region_returns = 1
                check_region_block(p, body)
                p.region_returns = 0
            }
        }
        i = i + 1
    }
}

check_calls :: fn(mut p: Parser) {
    mut i : i64 = 0
    while (i < p.arena.count) {
        node : ^Node = arena_at(p.arena, i)
        kind := node^.kind
        fn_index := node^.val
        args := node^.a
        if (kind == NODE_CALL) {
            sym : ^Sym = arena_at(p.fns, fn_index)
            defined := sym^.defined
            name_off := sym^.off
            name_len := sym^.len
            params := sym^.params
            if (defined == 0) {
                frost_error("frost: call to undefined function '")
                frost_error_src(p.src, name_off, name_len)
                frost_error("'")
                frost_die()
            }
            // The capability is supplied by the caller's context rather than
            // written at the call, so it is not one of the arguments counted.
            mut expected := count_params(p, params)
            if (sym^.uses_ty >= 0) {
                expected = expected - 1
            }
            got := count_args(p, args)
            if (expected != got) {
                frost_error("frost: '")
                frost_error_src(p.src, name_off, name_len)
                frost_error("' expects ")
                frost_error_int(expected)
                frost_error(" argument(s) but got ")
                frost_error_int(got)
                frost_die()
            }
        }
        i = i + 1
    }
}

main :: fn() -> i64 {
    // Compile the file named by the FROST_INPUT environment variable when it
    // is set (the self-hosting fixpoint feeds frost.frost itself through
    // here), and otherwise fall back to the built-in demonstration program.
    input_path := frost_getenv("FROST_INPUT")
    mut source : ^i8 = ""
    mut modules : Arena<Module> = arena_make($Module, 1024)
    mut exports : Arena<Export> = arena_make($Export, 4096)
    export_names := ptr_cast($i8, malloc(SYNTH_ROOM))
    if (frost_str_len(input_path) != 0) {
        // One buffer holds the root file and everything it imports, so a name
        // is an offset into a single source no matter which file wrote it.
        buffer := ptr_cast($i8, malloc(SOURCE_ROOM + SYNTH_ROOM))
        mut scratch : Arena<Token> = arena_make($Token, 262144)
        resolve_imports(buffer, input_path, export_names, modules, exports,
            scratch)
        source = buffer
    }
    if (frost_str_len(source) == 0) {
        source = "
        strlen :: extern fn(s: ^i8) -> i64

        ANSWER :: 42

        fib :: fn(n: i64) -> i64 {
            if (n < 2) { return n }
            return fib(n - 1) + fib(n - 2)
        }

        fact :: fn(n: i64) -> i64 {
            if (n < 1) { return 1 }
            return n * fact(n - 1)
        }

        Point :: struct { x: i64, y: i64 }

        sum_point :: fn(pt: Point) -> i64 {
            return pt.x + pt.y
        }

        bump :: fn(b: ^Point) {
            b^.x = b^.x + 1
        }

        classify :: fn(n: i64) -> i64 {
            mut result : i64 = 0
            match n {
                case 0: result = 100
                case 1: result = 200
                case _: result = 999
            }
            return result
        }

        Box :: struct($T: Type) { value: $T }

        Holder :: struct { item: Box<i64> }

        box_make :: fn($T: Type, v: $T) -> Box<T> {
            Box { value = v }
        }

        box_get :: fn(b: Box<$T>) -> $T {
            b^.value
        }

        main :: fn() -> i64 {
            print fib(10)
            print fact(5)
            mut sum : i64 = 0
            mut index : i64 = 1
            while (index <= 10) { sum = sum + index  index = index + 1 }
            print sum
            p := Point { x = 3, y = 4 }
            print p.x
            p.x = 10
            print sum_point(p)
            ptr := ptr_to(p)
            bump(ptr)
            print p.x
            print ptr^.y
            print ptr[0].x
            q := ptr_cast($Point, ptr)
            print q^.x
            print sizeof(Point)
            print classify(0)
            print classify(1)
            print classify(7)
            print strlen(\"hello\")
            print ANSWER
            h := Holder { item = box_make($i64, 77) }
            print box_get(h.item)
        }
    "
    }
    // The demo program is a literal with nowhere to write, so it needs the same
    // copy with room past the terminator that an imported source already has.
    if (frost_str_len(input_path) == 0) {
        source = source_with_room(source)
    }

    mut parser := Parser {
        src = source,
        tokens = arena_make($Token, 262144),
        ti = 0,
        arena = arena_make($Node, 262144),
        fns = arena_make($Sym, 8192),
        structs = arena_make($StructDef, 4096),
        fields = arena_make($StructField, 8192),
        locals = arena_make($LocalVar, 4096),
        consts = arena_make($ConstDef, 4096),
        instances = arena_make($Instance, 4096),
        generic_fns = arena_make($GenericFn, 256),
        type_param_off = 0,
        type_param_len = 0,
        type_binding = 0,
        binding_active = 0,
        saw_type_param = 0,
        last_return_type = 0,
        no_struct_lit = false,
        last_type_was_generic = 0,
        moved = arena_make($LocalVar, 4096),
        label_id = 0,
        abi_windows = 0,
        asm_temp = 0,
        asm_ret = 0,
        sret_slot = 0,
        mono_rets = arena_make($MonoRet, 1024),
        current_ret = 0,
        current_fn_off = 0,
        current_fn_len = 0,
        tainted = arena_make($LocalVar, 4096),
        inner = arena_make($LocalVar, 4096),
        region_off = 0,
        region_len = 0,
        region_returns = 0,
        modules = modules,
        exports = exports,
        export_names = export_names,
        result_ty = 0 - 1,
        failure_ty = 0 - 1,
        variants = arena_make($Variant, 4096),
        match_count = 0,
        pending = arena_make($LocalVar, 4096),
        try_count = 0,
        name_tag = 0,
        name_value = 0,
        name_error = 0,
        synth_next = 0,
        prov_kind = 0,
        prov_off = 0,
        prov_len = 0,
    }
    // Names the compiler synthesizes go past the source's terminator, so the
    // first free byte is one past the text.
    parser.synth_next = frost_str_len(source) + 1
    // The host convention by default; FROST_ABI overrides it so the other
    // target's output can be inspected from either host.
    parser.abi_windows = frost_is_windows()
    abi := frost_getenv("FROST_ABI")
    if (cstr_eq(abi, "sysv")) {
        parser.abi_windows = 0
    }
    if (cstr_eq(abi, "win")) {
        parser.abi_windows = 1
    }
    tokenize(source, frost_str_len(source), parser.tokens)
    program := parse_program(parser)
    record_mono_rets(parser)
    check_calls(parser)
    check_regions(parser)

    backend := frost_getenv("FROST_BACKEND")
    if (cstr_eq(backend, "asm")) {
        emit_asm_program(parser, program)
        return 0
    }
    frost_emit_str("#include <stdio.h>\n")
    frost_emit_str("#include <stdint.h>\n")
    emit_program(parser, program)
    0
}
