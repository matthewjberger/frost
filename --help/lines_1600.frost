work1598 :: fn(x: i64, y: i64) -> i64 {
    mut acc : i64 = x
    mut j : i64 = 0
    while (j < 4) { acc = acc + y * j  j = j + 1 }
    s := S1598 { a = acc, b = y }
    s.a + s.b
}

S1599 :: struct { a: i64, b: i64 }
work1599 :: fn(x: i64, y: i64) -> i64 {
    mut acc : i64 = x
    mut j : i64 = 0
    while (j < 4) { acc = acc + y * j  j = j + 1 }
    s := S1599 { a = acc, b = y }
    s.a + s.b
}

