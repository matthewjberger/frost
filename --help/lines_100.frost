printf :: extern fn(fmt: ^i8, value: i64) -> i32

S0 :: struct { a: i64, b: i64 }
work0 :: fn(x: i64, y: i64) -> i64 {
    mut acc : i64 = x
    mut j : i64 = 0
    while (j < 4) { acc = acc + y * j  j = j + 1 }
    s := S0 { a = acc, b = y }
    s.a + s.b
}

