// The slab as a library: one generic implementation, used at two element types
// in the same program, each instantiation stamped out separately with no
// runtime dispatch and no shared type-erased storage.
//
// This is the point of `$T` and `$N` together. `Slab<Entity, 8>` and
// `Slab<Tile, 4>` are different types with different layouts, and the operations
// over them are the same source.

import "io.frost"

import "slab.frost"

Entity :: struct { hp: i64, mana: i64 }
Tile :: struct { height: i64 }

show :: fn(flag: bool) { if (flag) { print_int_line(1) } else { print_int_line(0) } }

main :: fn() -> i64 {
    mut world : Slab<Entity, 8> = Slab {
        storage = [Entity { hp = 0, mana = 0 }; 8],
        generations = [0; 8],
        free_list = [0; 8],
        free_count = 0,
    }
    slab_reset($Entity, $8, world)

    h := slab_insert($Entity, $8, world, Entity { hp = 100, mana = 30 })
    print_int_line(world[h].hp)  // 100
    print_int_line(world[h].mana)  // 30
    world[h].hp = 75
    print_int_line(world[h].hp)  // 75

    // The same code at a different element type and a different capacity.
    mut ground : Slab<Tile, 4> = Slab {
        storage = [Tile { height = 0 }; 4],
        generations = [0; 4],
        free_list = [0; 4],
        free_count = 0,
    }
    slab_reset($Tile, $4, ground)
    t := slab_insert($Tile, $4, ground, Tile { height = 12 })
    print_int_line(ground[t].height)  // 12

    show(slab_alive($Entity, $8, world, h))     // 1
    show(slab_release($Entity, $8, world, h))   // 1
    show(slab_alive($Entity, $8, world, h))     // 0
    0
}
